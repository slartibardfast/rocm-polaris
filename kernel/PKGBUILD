export KBUILD_BUILD_HOST=archlinux
export KBUILD_BUILD_USER=$pkgbase
export KBUILD_BUILD_TIMESTAMP="$(date -Ru${SOURCE_DATE_EPOCH:+d @$SOURCE_DATE_EPOCH})"

prepare() {
  cd $_srcname

  echo "Setting version..."
  echo "-$pkgrel" > localversion.10-pkgrel
  echo "${pkgbase#linux}" > localversion.20-pkgname

  local src
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    src="${src%.zst}"
    [[ $src = *.patch ]] || continue
    echo "Applying patch $src..."
    patch -Np1 < "../$src"
  done

  # Wait for TLB invalidation completion on gmc_v8 (defense-in-depth).
  local _gmc=drivers/gpu/drm/amd/amdgpu/gmc_v8_0.c
  sed -i '/WREG32(mmVM_INVALIDATE_REQUEST, 1 << vmid);$/{
    a\
\n\t/* Wait for TLB invalidation to complete. */\
\t{\
\t\tunsigned int i;\
\t\tfor (i = 0; i < adev->usec_timeout; i++) {\
\t\t\tif (RREG32(mmVM_INVALIDATE_RESPONSE) \& (1 << vmid))\
\t\t\t\tbreak;\
\t\t\tudelay(1);\
\t\t}\
\t}
  }' "$_gmc"

  # Flush pending KFD eviction restore before returning from alloc/map
  # ioctls.  VRAM allocation can trigger process eviction (queues stopped,
  # BOs unmapped) with restore deferred by PROCESS_RESTORE_TIME_MS (100ms).
  # Without flushing, the ioctl returns while queues are still stopped,
  # and the next dispatch VM-faults on unmapped internal structures.
  local _kfd=drivers/gpu/drm/amd/amdkfd/kfd_chardev.c
  # In kfd_ioctl_alloc_memory_of_gpu: flush before returning handle.
  # Use python for precise insertion at the right return point.
  python3 -c "
import re
with open('$_kfd') as f: s = f.read()
# Insert after 'mutex_unlock(&p->mutex);' in alloc_memory_of_gpu only.
# The function has a unique 'MAKE_HANDLE(args->gpu_id, idr_handle)' line.
old = 'args->handle = MAKE_HANDLE(args->gpu_id, idr_handle);'
new = 'flush_delayed_work(&p->eviction_work);\n\n\targs->handle = MAKE_HANDLE(args->gpu_id, idr_handle);'
s = s.replace(old, new, 1)  # replace first occurrence only (alloc ioctl)
# In kfd_ioctl_map_memory_to_gpu: flush before return on success path.
# The success return is 'kfree(devices_arr);\n\n\treturn err;' (line 1342-1344).
old2 = 'kfree(devices_arr);\n\n\treturn err;'
new2 = 'kfree(devices_arr);\n\tflush_delayed_work(&p->eviction_work);\n\n\treturn err;'
s = s.replace(old2, new2, 1)  # replace first occurrence only (map ioctl success)
with open('$_kfd', 'w') as f: f.write(s)
"

  # Enable TLB flush after unmap on gfx8.
  sed -i 's/KFD_GC_VERSION(dev) >= IP_VERSION(9, 4, 2)/KFD_GC_VERSION(dev) >= IP_VERSION(8, 0, 0)/' \
    drivers/gpu/drm/amd/amdkfd/kfd_priv.h

  # Upgrade map_memory TLB flush to HEAVYWEIGHT for gfx8.
  sed -i 's/kfd_flush_tlb(peer_pdd, TLB_FLUSH_LEGACY);/kfd_flush_tlb(peer_pdd, TLB_FLUSH_HEAVYWEIGHT);/' "$_kfd"

  # Wait for ALL pending VM page table updates before returning from
  # map_memory_to_gpu.  The sync_memory call only waits on the user BO's
  # fences.  During alloc/free/realloc, TTM evicts internal BOs whose PTE
  # updates go through separate fence chains (vm->immediate/delayed entities).
  # Without waiting on these, the next dispatch can hit stale PTEs for
  # evicted/remapped internal structures.
  python3 -c "
with open('$_kfd') as f: s = f.read()
# Insert amdgpu_vm_wait_idle after sync_memory in map_memory_to_gpu.
# Target the unique 'mutex_unlock(&p->mutex);' followed by
# 'Flush TLBs after waiting' comment.
s = s.replace(
    'mutex_unlock(&p->mutex);\n\n\t/* Flush TLBs after waiting for the page table updates to complete */',
    'mutex_unlock(&p->mutex);\n\n\t/* Wait for ALL VM page table updates including evicted BO remaps. */\n\t{\n\t\tstruct amdgpu_vm *vm = drm_priv_to_vm(pdd->drm_priv);\n\t\tamdgpu_vm_wait_idle(vm, MAX_SCHEDULE_TIMEOUT);\n\t}\n\n\t/* Flush TLBs after waiting for the page table updates to complete */',
    1)
with open('$_kfd', 'w') as f: f.write(s)
"

  # Add TLB flush to kfd_ioctl_free_memory_of_gpu.  The free ioctl has NO
  # TLB flush — freed VA ranges retain stale TLB entries.  When the VA is
  # reused by the next hipMalloc, the GPU reads stale PTEs → VM fault.
  # The unmap ioctl has a conditional flush (kfd_flush_tlb_after_unmap) but
  # hipFree goes through the free ioctl, bypassing it entirely.
  python3 -c "
with open('$_kfd') as f: s = f.read()
s = s.replace(
    'ret = amdgpu_amdkfd_gpuvm_free_memory_of_gpu(pdd->dev->adev,\n\t\t\t\t(struct kgd_mem *)mem, pdd->drm_priv, &size);\n\n\t/* If freeing the buffer failed',
    'ret = amdgpu_amdkfd_gpuvm_free_memory_of_gpu(pdd->dev->adev,\n\t\t\t\t(struct kgd_mem *)mem, pdd->drm_priv, &size);\n\n\t/* Flush TLB to clear stale entries for the freed VA range. */\n\tif (!ret)\n\t\tkfd_flush_tlb(pdd, TLB_FLUSH_HEAVYWEIGHT);\n\n\t/* If freeing the buffer failed',
    1)
with open('$_kfd', 'w') as f: f.write(s)
"

  # Log fault VA details for debugging GPUVM page table issues.
  # The VMID, fault VA, and protection status are already logged by the
  # existing handler.  Add the page table base address for the faulting
  # VMID so we can cross-reference with debugfs.
  python3 -c "
with open('$_gmc') as f: s = f.read()
old = 'if (!addr && !status)\n\t\treturn 0;'
new = '''if (!addr && !status)
\t\treturn 0;

\t/* Log the page table base for the faulting VMID. */
\t{
\t\tu32 vm_reg;
\t\tvmid = REG_GET_FIELD(status, VM_CONTEXT1_PROTECTION_FAULT_STATUS, VMID);
\t\tif (vmid < 8)
\t\t\tvm_reg = RREG32(mmVM_CONTEXT0_PAGE_TABLE_BASE_ADDR + vmid);
\t\telse
\t\t\tvm_reg = RREG32(mmVM_CONTEXT8_PAGE_TABLE_BASE_ADDR + vmid - 8);
\t\tdev_err(adev->dev, \"VMID %u PT base = 0x%x (pages), fault VA = 0x%llx\\\\n\",
\t\t\tvmid, vm_reg, ((u64)addr) << 12);
\t}'''
s = s.replace(old, new, 1)
with open('$_gmc', 'w') as f: f.write(s)
"

  # Phase 7h: Expose HDP flush register to userspace on VI (gfx8).
  # Based on Huang Rui's (AMD) patch for Carrizo HDP remap, confirmed
  # VI-generic by Felix Kuehling (applies to Fiji/Polaris dGPUs).
  #
  # The HDP_MEM_COHERENCY_FLUSH_CNTL register (0x1520 in BIF 5.1) is
  # already used by vi_flush_hdp() in the kernel.  We remap it to a
  # userspace-accessible MMIO page so that ROCR and CLR can flush the
  # HDP path after CPU writes to system memory, making data visible
  # to the GPU L2 cache.
  #
  # BIF 5.1 remap registers:
  #   mmREMAP_HDP_MEM_FLUSH_CNTL (0x1426): configures where writes to
  #     the remap page get forwarded — set ADDRESS field to point to
  #     mmHDP_MEM_COHERENCY_FLUSH_CNTL (0x1520)
  #   mmREMAP_HDP_REG_FLUSH_CNTL (0x1427): same for reg flush variant
  #
  # MMIO BAR is 256KB (0x40000).  We use the last page (0x3F000) as
  # the remap target, same pattern as NBIO v7's MMIO_REG_HOLE_OFFSET.
  local _vi=drivers/gpu/drm/amd/amdgpu/vi.c
  python3 -c "
with open('$_vi') as f: s = f.read()

# Add rmmio_remap initialization at the end of vi_common_early_init,
# just before the 'return 0;' at the function end.
# Also program the BIF remap registers to point to the HDP flush regs.

old = 'static void vi_flush_hdp(struct amdgpu_device *adev, struct amdgpu_ring *ring)'
new = '''/* Phase 7h: Expose HDP flush registers to userspace via MMIO remap.
 * Based on Huang Rui's VI HDP remap patch for Carrizo.
 * Programs BIF 5.1 remap registers to forward writes to the last page
 * of the MMIO BAR to HDP_MEM_COHERENCY_FLUSH_CNTL / HDP_REG_COHERENCY_FLUSH_CNTL.
 * KFD exposes this as HSA_HEAPTYPE_MMIO_REMAP for userspace HDP flush.
 */
static void vi_set_reg_remap(struct amdgpu_device *adev)
{
\tif (!amdgpu_sriov_vf(adev) && (PAGE_SIZE <= 4096)) {
\t\t/* Use last page of MMIO BAR as remap target */
\t\tuint32_t remap_offset = adev->rmmio_size - PAGE_SIZE;
\t\tadev->rmmio_remap.reg_offset = remap_offset;
\t\tadev->rmmio_remap.bus_addr = adev->rmmio_base + remap_offset;
\t\t/* Program BIF remap registers:
\t\t * REMAP_HDP_MEM_FLUSH_CNTL.ADDRESS = mmHDP_MEM_COHERENCY_FLUSH_CNTL
\t\t * REMAP_HDP_REG_FLUSH_CNTL.ADDRESS = mmHDP_REG_COHERENCY_FLUSH_CNTL
\t\t */
\t\t/* Remap to HDP_MEM/REG_COHERENCY_FLUSH_CNTL for userspace
\t\t * HDP flush (write-only — BIF remap does not forward reads).
\t\t * For completion-tracked flush, use the KFD_IOC_HDP_FLUSH ioctl
\t\t * which does WREG32/RREG32 on GPU_HDP_FLUSH_REQ/DONE directly.
\t\t */
\t\tWREG32(mmREMAP_HDP_MEM_FLUSH_CNTL, mmHDP_MEM_COHERENCY_FLUSH_CNTL);
\t\tWREG32(mmREMAP_HDP_REG_FLUSH_CNTL, mmHDP_REG_COHERENCY_FLUSH_CNTL);
\t} else {
\t\tadev->rmmio_remap.reg_offset = mmHDP_MEM_COHERENCY_FLUSH_CNTL << 2;
\t\tadev->rmmio_remap.bus_addr = 0;
\t}

}


static void vi_flush_hdp(struct amdgpu_device *adev, struct amdgpu_ring *ring)'''
assert old in s, 'vi_flush_hdp pattern not found'
s = s.replace(old, new, 1)

# Call vi_set_reg_remap from vi_common_hw_init
# Find the right place — after basic HW init but before KFD init
old2 = 'static const struct amd_ip_funcs vi_common_ip_funcs'
s = s.replace(
    old2,
    '/* Phase 7h: Call remap setup during HW init */\\nstatic void vi_common_late_init_remap(struct amdgpu_device *adev)\\n{\\n\\tvi_set_reg_remap(adev);\\n}\\n\\n' + old2,
    1)

# Hook vi_common_late_init_remap into the early_init function
# by adding it to the end of vi_common_early_init
old3 = '\\treturn 0;\\n}\\n\\nstatic int vi_common_late_init'
new3 = '\\tvi_set_reg_remap(adev);\\n\\treturn 0;\\n}\\n\\nstatic int vi_common_late_init'
if old3 in s:
    s = s.replace(old3, new3, 1)
else:
    # Fallback: inject into vi_common_hw_init
    print('WARNING: could not find vi_common_early_init return; trying hw_init')

with open('$_vi', 'w') as f: f.write(s)
print('OK: Phase 7h vi_set_reg_remap applied')
"

  # Also need mmREMAP_HDP_MEM_FLUSH_CNTL and mmHDP_REG_COHERENCY_FLUSH_CNTL
  # includes. vi.c already includes bif_5_1_d.h (has the remap defines) and
  # uses mmHDP_MEM_COHERENCY_FLUSH_CNTL (from same header). Check:
  grep -q 'mmHDP_MEM_COHERENCY_FLUSH_CNTL' "$_srcname/$_vi" && \
    echo "HDP register already referenced in vi.c" || \
    echo "WARNING: HDP register not found in vi.c"

  # Check mmHDP_REG_COHERENCY_FLUSH_CNTL is defined
  grep -q 'mmHDP_REG_COHERENCY_FLUSH_CNTL' "$_srcname/drivers/gpu/drm/amd/include/asic_reg/bif/bif_5_1_d.h" && \
    echo "HDP_REG_COHERENCY_FLUSH_CNTL found in bif_5_1_d.h" || \
    echo "WARNING: need to check HDP_REG register name"

  # Phase 7h: KFD ioctl for completion-tracked HDP flush.
  # BIF remap only forwards WRITES, not READS — can't poll FLUSH_DONE
  # from userspace.  This ioctl does the REQ/DONE protocol in kernel space.
  local _kfd=drivers/gpu/drm/amd/amdkfd/kfd_chardev.c
  local _ioctl_h="include/uapi/linux/kfd_ioctl.h"
  python3 -c "
import re

# 1. Add ioctl struct and number to kfd_ioctl.h
with open('$_ioctl_h') as f: h = f.read()

# Add struct before AMDKFD_COMMAND_START
hdp_struct = '''
/* Phase 7h: Completion-tracked HDP flush */
struct kfd_ioctl_hdp_flush_args {
\t__u32 gpu_id;
\t__u32 flush_mask;
\t__u32 queue_id;
\t__u32 timeout_us;
\t__u32 actual_us;
\t__u32 status;
};

'''
h = h.replace('#define AMDKFD_COMMAND_START', hdp_struct + '#define AMDKFD_COMMAND_START')

# Add ioctl number and bump COMMAND_END
h = h.replace(
    '#define AMDKFD_COMMAND_END\\t\\t0x27',
    '#define AMDKFD_IOC_HDP_FLUSH\\t\\t\\\\\\n\\tAMDKFD_IOWR(0x27, struct kfd_ioctl_hdp_flush_args)\\n\\n#define AMDKFD_COMMAND_END\\t\\t0x28')

with open('$_ioctl_h', 'w') as f: f.write(h)
print('OK: kfd_ioctl.h updated')

# 2. Add handler to kfd_chardev.c
with open('$_kfd') as f: s = f.read()

handler = '''#include \"asic_reg/bif/bif_5_1_d.h\"
#include \"vid.h\"

static int kfd_flush_gpu_l2(struct kfd_process_device *pdd);

/* Phase 7h: Completion-tracked HDP flush for no-atomics platforms. */
static int kfd_ioctl_hdp_flush(struct file *filp,
\t\tstruct kfd_process *p, void *data)
{
\tstruct kfd_ioctl_hdp_flush_args *args = data;
\tstruct kfd_process_device *pdd;
\tstruct amdgpu_device *adev;
\tuint32_t mask = args->flush_mask;
\tuint32_t timeout_us = args->timeout_us ? args->timeout_us : 10000;
\tuint32_t tmp;
\tktime_t start;

\t/* Find the GPU device */
\tmutex_lock(&p->mutex);
\tpdd = kfd_process_device_data_by_id(p, args->gpu_id);
\tif (!pdd && p->n_pdds > 0)
\t\tpdd = p->pdds[0]; /* first GPU if gpu_id=0 */
\tif (!pdd) {
\t\tmutex_unlock(&p->mutex);
\t\treturn -EINVAL;
\t}
\tadev = pdd->dev->adev;
\tif (!mask) mask = 0x3FC; /* all compute CPs */
\tmutex_unlock(&p->mutex);

\t/* REQ/DONE protocol */
\tstart = ktime_get();
\tWREG32(mmGPU_HDP_FLUSH_REQ, mask);
\tdo {
\t\ttmp = RREG32(mmGPU_HDP_FLUSH_DONE);
\t\tif ((tmp & mask) == mask) {
\t\t\tkfd_flush_gpu_l2(pdd);
\t\t\targs->status = 0;
\t\t\targs->actual_us = (uint32_t)ktime_us_delta(ktime_get(), start);
\t\t\treturn 0;
\t\t}
\t\tudelay(1);
\t} while (ktime_us_delta(ktime_get(), start) < timeout_us);

\t/* Even on HDP timeout, flush L2 via GFX ring */
\tkfd_flush_gpu_l2(pdd);

\targs->status = 1;
\targs->actual_us = timeout_us;
\treturn 0;
}

/* Phase 7h: GPU L2 writeback via GFX ring fence.
 * The MEC (compute) ring's TC_WB is unreliable on gfx8.
 * The GFX ring's TC_WB is proven (used for every kernel fence).
 * This function submits an EVENT_WRITE_EOP with TC_WB on the GFX ring
 * and polls for completion. Called after D2H blit to ensure GPU L2
 * dirty lines (staging buffer) are written back to DRAM.
 */
static int kfd_flush_gpu_l2(struct kfd_process_device *pdd)
{
\tstruct amdgpu_device *adev = pdd->dev->adev;
\tstruct amdgpu_ring *ring = &adev->gfx.gfx_ring[0];
\tint r;

\t/* Use the GFX ring's existing fence mechanism to flush L2.
\t * amdgpu_ring_emit_fence handles the EVENT_WRITE_EOP with
\t * TC_WB + TC_ACTION flags. We just need to emit a fence and
\t * wait for it to complete.
\t */
\tmutex_lock(&adev->gfx.gpu_clock_mutex);  /* protect GFX ring */

\tr = amdgpu_ring_alloc(ring, 16);
\tif (r) {
\t\tmutex_unlock(&adev->gfx.gpu_clock_mutex);
\t\treturn r;
\t}

\t/* Emit fence with cache flush (same as kernel driver's fence emit) */
\tring->funcs->emit_fence(ring, ring->fence_drv.gpu_addr,
\t\t\t\t++ring->fence_drv.sync_seq,
\t\t\t\tAMDGPU_FENCE_FLAG_64BIT);
\tamdgpu_ring_commit(ring);

\t/* Wait for fence completion (L2 flushed when fence value appears) */
\t{
\t\tvolatile uint64_t *fence_ptr = (volatile uint64_t *)
\t\t\t((char *)adev->wb.wb +
\t\t\t (ring->fence_drv.gpu_addr - adev->wb.gpu_addr));
\t\tint timeout = 10000;
\t\twhile (*fence_ptr < ring->fence_drv.sync_seq && --timeout > 0)
\t\t\tudelay(1);
\t}

\tmutex_unlock(&adev->gfx.gpu_clock_mutex);
\treturn 0;
}

'''

# Insert before kfd_ioctl_get_version
old = 'static int kfd_ioctl_get_version(struct file *filep, struct kfd_process *p,'
assert old in s, 'kfd_ioctl_get_version not found'
s = s.replace(old, handler + old, 1)

# Add to ioctl table — after the last entry (DBG_TRAP)
old_table = 'AMDKFD_IOCTL_DEF(AMDKFD_IOC_DBG_TRAP,\\n\\t\\t\\tkfd_ioctl_set_debug_trap, 0),'
new_table = old_table + '\\n\\tAMDKFD_IOCTL_DEF(AMDKFD_IOC_HDP_FLUSH,\\n\\t\\t\\tkfd_ioctl_hdp_flush, 0),'
s = s.replace(old_table, new_table, 1)

# bif_5_1_d.h included directly in the handler function above

with open('$_kfd', 'w') as f: f.write(s)
print('OK: kfd_chardev.c ioctl handler + table entry added')
"

  # Also upgrade vi_flush_hdp to use REQ/DONE for kernel-side flushes
  python3 -c "
with open('$_vi') as f: s = f.read()
old = 'static void vi_flush_hdp(struct amdgpu_device *adev, struct amdgpu_ring *ring)\\n{\\n\\tif (!ring || !ring->funcs->emit_wreg) {\\n\\t\\tWREG32(mmHDP_MEM_COHERENCY_FLUSH_CNTL, 1);\\n\\t\\tRREG32(mmHDP_MEM_COHERENCY_FLUSH_CNTL);'
new = '''static void vi_flush_hdp(struct amdgpu_device *adev, struct amdgpu_ring *ring)
{
\\tif (!ring || !ring->funcs->emit_wreg) {
\\t\\t/* Phase 7h: REQ/DONE completion-tracked flush */
\\t\\tuint32_t tmp;
\\t\\tint timeout = 10000;
\\t\\tWREG32(mmGPU_HDP_FLUSH_REQ, 0xFFF);
\\t\\tdo {
\\t\\t\\ttmp = RREG32(mmGPU_HDP_FLUSH_DONE);
\\t\\t\\tif ((tmp & 0xFFF) == 0xFFF)
\\t\\t\\t\\tbreak;
\\t\\t\\tudelay(1);
\\t\\t} while (--timeout > 0);'''
if old in s:
    s = s.replace(old, new, 1)
    print('OK: vi_flush_hdp upgraded to REQ/DONE (10ms timeout)')
else:
    print('WARNING: vi_flush_hdp pattern not found')
with open('$_vi', 'w') as f: f.write(s)
"

  # Phase 7h: Fix GPU L2 stale reads for MTYPE_UC system memory.
  #
  # On VI (gfx8), SH_MEM_CONFIG sets DEFAULT_MTYPE=MTYPE_UC for the
  # SHARED aperture (system memory) on compute queues.  The hardware
  # default L2 load policy for MTYPE_UC is MISS_LRU (0x0) — GPU L2
  # caches system memory reads with normal LRU replacement.
  #
  # On platforms without PCIe atomics (e.g. Westmere PCIe 2.0), there
  # is no coherency protocol to invalidate GPU L2 when the CPU writes
  # new data to system memory.  L2 serves stale data when addresses
  # are reused (kernarg pool, AQL ring, staging buffers).
  #
  # Fix: Set POLICY_3 (MTYPE_UC) to MISS_EVICT (0x1) in
  # TC_CFG_L2_LOAD_POLICY0.  MISS_EVICT allocates on L2 miss but marks
  # the line as lowest-priority for eviction — preserves intra-dispatch
  # L2 caching but ensures lines are evicted between dispatches.
  #
  # Scope: only MTYPE_UC data loads (SHARED aperture = system memory).
  # VRAM uses PTE-based coherency (SNOOPED bit), not SH_MEM_CONFIG MTYPE.
  # Instruction fetch unaffected (SQC/CP use CP_CPC_IC_BASE_CNTL MTYPE).
  # TC_CFG_L2_LOAD_POLICY0 is global (unified L2), not per-SE.
  #
  # Must be in gfx_v8_0_hw_init AFTER gfx_v8_0_init_golden_registers
  # (GCA block must be powered up for TC registers to latch).
  local _gfx8=drivers/gpu/drm/amd/amdgpu/gfx_v8_0.c
  python3 -c "
with open('$_gfx8') as f: s = f.read()
old = '\tgfx_v8_0_init_golden_registers(adev);\n\tgfx_v8_0_constants_init(adev);'
new = '''\tgfx_v8_0_init_golden_registers(adev);

\t/* Phase 7h: Fix GPU L2 stale reads for MTYPE_UC system memory.
\t * Hardware default TC_CFG_L2_LOAD_POLICY0 = 0x0 (MISS_LRU for all MTYPEs).
\t * Set POLICY_3 (MTYPE_UC, bits [7:6]) to MISS_EVICT (1).
\t * Only affects system memory reads (SHARED aperture).  VRAM unaffected.
\t * Blind write — hardware default is 0x0, no need for read-modify-write.
\t */
\t/* REVERTED: MISS_EVICT may cause premature L2 eviction */
\t/* WREG32(mmTC_CFG_L2_LOAD_POLICY0, 0x40); */

\tgfx_v8_0_constants_init(adev);'''
assert old in s, 'gfx_v8_0_hw_init golden+constants pattern not found'
s = s.replace(old, new, 1)
with open('$_gfx8', 'w') as f: f.write(s)
print('OK: TC_CFG_L2_LOAD_POLICY0 MISS_EVICT applied in gfx_v8_0_hw_init')
"

  # gfx_v8_0.c needs gfx_8_0_d.h for mmTC_CFG_L2_LOAD_POLICY0 (already included)
  grep -q 'gfx_8_0_d.h' "$_srcname/$_gfx8" && \
    echo "gfx_8_0_d.h already included in gfx_v8_0.c" || \
    echo "WARNING: gfx_8_0_d.h not included in gfx_v8_0.c"

  # Phase 7h: Set DISPATCH_CACHE_CNTL=1 in MQD for no-atomics compute queues.
  #
  # DISPATCH_CACHE_CNTL (bits [9:7] of COMPUTE_DISPATCH_INITIATOR) controls
  # per-dispatch L1/L2 cache policy.  Value 1 = "miss/evict for L1, bypass
  # for L2" (GCN3 ISA §MODE register / DISPATCH_CACHE_CTRL).
  #
  # For AQL queues, the CP constructs COMPUTE_DISPATCH_INITIATOR from the
  # AQL packet + MQD template.  Setting DISPATCH_CACHE_CNTL in the MQD
  # makes every dispatch from that queue bypass L2 for system memory reads.
  #
  # Guard: atc_bit=0 (no ATC = no PCIe atomics on dGPU).  Platforms with
  # atomics don't need this — their coherency protocol handles L2.
  #
  # Combined with TC_CFG_L2_LOAD_POLICY0 MISS_EVICT, this provides two
  # independent defenses against GPU L2 stale reads on no-atomics platforms.
  local _mqd_vi=drivers/gpu/drm/amd/amdkfd/kfd_mqd_manager_vi.c
  python3 -c "
with open('$_mqd_vi') as f: s = f.read()
old = '\tm = get_mqd(mqd);\n\n\tm->cp_hqd_pq_control ='
new = '''\tm = get_mqd(mqd);

\t/* Phase 7h: DISPATCH_CACHE_CNTL REVERTED.
\t * L2 bypass causes blit kernel to read STALE VRAM data — compute
\t * kernel writes are in L2, not yet flushed to VRAM MC.  Bypassing
\t * L2 makes blit read old data from MC, corrupting D2H copies.
\t */

\tm->cp_hqd_pq_control ='''
assert old in s, '__update_mqd get_mqd+cp_hqd_pq_control pattern not found'
s = s.replace(old, new, 1)
## Also set CP PQ CACHE_POLICY=1 (MISS_EVICT) for no-atomics platforms.
## CP_HQD_PQ_CONTROL__CACHE_POLICY controls the CP's own cache policy
## for reading AQL packets from the ring buffer.  Default is 0 (MISS_LRU)
## which lets the CP cache ring slot data and serve stale packets when
## slots are reused.  MISS_EVICT marks fetched packets for immediate
## eviction from the CP's internal buffer.
##
## This is the CP-side equivalent of TC_CFG_L2_LOAD_POLICY for shader L2.
## Without this, the CP reads stale AQL packets (kernarg_address=0) when
## ring slots wrap.
if '!atc_bit' not in s:
    ## Pattern already applied by compute_dispatch_initiator injection above
    pass
pq_old = 'CP_HQD_PQ_CONTROL__UNORD_DISPATCH_MASK;'
pq_new = 'CP_HQD_PQ_CONTROL__UNORD_DISPATCH_MASK;\n\tif (!atc_bit)\n\t\tm->cp_hqd_pq_control |= 1 << CP_HQD_PQ_CONTROL__CACHE_POLICY__SHIFT;'
assert pq_old in s, 'CP_HQD_PQ_CONTROL UNORD_DISPATCH pattern not found'
s = s.replace(pq_old, pq_new, 1)

with open('$_mqd_vi', 'w') as f: f.write(s)
print('OK: DISPATCH_CACHE_CNTL=1 + PQ CACHE_POLICY=1 set for no-atomics')
"

  # Phase 13: DOORBELL_BIF_DROP — REVERTED. Caused dispatch hangs on
  # gfx8/no-atomics. BIF drops doorbell writes when it shouldn't.
  # IQ_TIMER WAIT_TIME — also REVERTED (same reason, CP stalls).
  # Both MQD knobs are incompatible with our no-atomics dispatch path.

  # Phase 13: Allow CPU-visible VRAM allocations on small-BAR systems.
  # KFD rejects PUBLIC|VRAM on small BAR as a safety guard, but small
  # allocations (AQL ring ~1MB) easily fit in the 256MB visible window.
  # Relax to a size check: allow if it fits in visible_vram_size.
  python3 -c "
with open('$_kfd') as f: s = f.read()
old = '''if ((flags & KFD_IOC_ALLOC_MEM_FLAGS_PUBLIC) &&
\t\t(flags & KFD_IOC_ALLOC_MEM_FLAGS_VRAM) &&
\t\t!kfd_dev_is_large_bar(dev)) {
\t\tpr_err(\"Alloc host visible vram on small bar is not allowed\\\n\");
\t\terr = -EINVAL;
\t\tgoto err_large_bar;
\t}'''
new = '''if ((flags & KFD_IOC_ALLOC_MEM_FLAGS_PUBLIC) &&
\t\t(flags & KFD_IOC_ALLOC_MEM_FLAGS_VRAM) &&
\t\t!kfd_dev_is_large_bar(dev)) {
\t\t/* Phase 13: allow if allocation fits in visible VRAM window.
\t\t * CPU_ACCESS_REQUIRED (set by PUBLIC) ensures BO placement
\t\t * within BAR aperture via amdgpu_bo_create. */
\t\tif (args->size > dev->local_mem_info.local_mem_size_public) {
\t\t\tpr_err(\"Alloc host visible vram (%llu) exceeds visible window (%llu)\\\n\",
\t\t\t\targs->size, dev->local_mem_info.local_mem_size_public);
\t\t\terr = -EINVAL;
\t\t\tgoto err_large_bar;
\t\t}
\t}'''
assert old in s, 'small-BAR PUBLIC VRAM rejection not found'
s = s.replace(old, new, 1)
with open('$_kfd', 'w') as f: f.write(s)
print('OK: Phase 13 small-BAR visible VRAM relaxed')
"

  # Phase 13 Fix 2: Report visible VRAM as a PUBLIC memory bank in topology.
  # On small-BAR, kfd_crat.c reports ALL VRAM as one PRIVATE bank.
  # Split into: PUBLIC bank (256MB visible) + PRIVATE bank (1.75GB invisible).
  # This lets ROCR create a coarsegrain_allocator with HostAccess=1.
  local _crat=drivers/gpu/drm/amd/amdkfd/kfd_crat.c
  python3 -c "
with open('$_crat') as f: s = f.read()
old = '''\telse
\t\tret = kfd_fill_gpu_memory_affinity(&avail_size,
\t\t\t\tkdev, HSA_MEM_HEAP_TYPE_FB_PRIVATE,
\t\t\t\tlocal_mem_info.local_mem_size_public +
\t\t\t\tlocal_mem_info.local_mem_size_private,
\t\t\t\t(struct crat_subtype_memory *)sub_type_hdr,
\t\t\t\tproximity_domain,
\t\t\t\t&local_mem_info);'''
new = '''\telse {
\t\t/* Phase 13: split visible VRAM as PUBLIC bank so userspace
\t\t * can allocate CPU-accessible VRAM (AQL ring buffers). */
\t\tif (local_mem_info.local_mem_size_public > 0) {
\t\t\tret = kfd_fill_gpu_memory_affinity(&avail_size,
\t\t\t\t\tkdev, HSA_MEM_HEAP_TYPE_FB_PUBLIC,
\t\t\t\t\tlocal_mem_info.local_mem_size_public,
\t\t\t\t\t(struct crat_subtype_memory *)sub_type_hdr,
\t\t\t\t\tproximity_domain,
\t\t\t\t\t&local_mem_info);
\t\t\tif (ret < 0)
\t\t\t\treturn ret;
\t\t\tsub_type_hdr = (typeof(sub_type_hdr))((char *)sub_type_hdr +
\t\t\t\t\tsub_type_hdr->length);
\t\t}
\t\tret = kfd_fill_gpu_memory_affinity(&avail_size,
\t\t\t\tkdev, HSA_MEM_HEAP_TYPE_FB_PRIVATE,
\t\t\t\tlocal_mem_info.local_mem_size_private,
\t\t\t\t(struct crat_subtype_memory *)sub_type_hdr,
\t\t\t\tproximity_domain,
\t\t\t\t&local_mem_info);
\t}'''
assert old in s, 'CRAT PRIVATE-only VRAM bank not found'
s = s.replace(old, new, 1)
with open('$_crat', 'w') as f: f.write(s)
print('OK: Phase 13 visible VRAM reported as PUBLIC bank')
"

  echo "Setting config..."
  cp ../config .config
  make olddefconfig
  diff -u ../config .config || :

  make -s kernelrelease > version
  echo "Prepared $pkgbase version $(<version)"
}

build() {
  cd $_srcname
  make all
  make -C tools/bpf/bpftool vmlinux.h feature-clang-bpf-co-re=1
}

_package() {
  pkgdesc="The $pkgdesc kernel and modules"
  license=(GPL-2.0-only)
  depends=(
    coreutils
    initramfs
    kmod
  )
  optdepends=(
    'wireless-regdb: to set the correct wireless channels of your country'
    'linux-firmware: firmware images needed for some devices'
  )
  provides=(
    KSMBD-MODULE
    VIRTUALBOX-GUEST-MODULES
    WIREGUARD-MODULE
    linux-lts=$pkgver
  )
  conflicts=(linux-lts)

  cd $_srcname
  local modulesdir="$pkgdir/usr/lib/modules/$(<version)"

  echo "Installing boot image..."
  install -Dm644 "$(make -s image_name)" "$modulesdir/vmlinuz"

  echo "$pkgbase" | install -Dm644 /dev/stdin "$modulesdir/pkgbase"

  echo "Installing modules..."
  ZSTD_CLEVEL=19 make INSTALL_MOD_PATH="$pkgdir/usr" INSTALL_MOD_STRIP=1 \
    DEPMOD=/doesnt/exist modules_install

  rm "$modulesdir"/build
}

_package-headers() {
  pkgdesc="Headers and scripts for building modules for the $pkgdesc kernel"
  license=(GPL-2.0-only)
  depends=(pahole)
  provides=(
    LINUX-HEADERS
    linux-lts-headers=$pkgver
  )
  conflicts=(linux-lts-headers)

  cd $_srcname
  local builddir="$pkgdir/usr/lib/modules/$(<version)/build"

  echo "Installing build files..."
  install -Dt "$builddir" -m644 .config Makefile Module.symvers System.map \
    localversion.* version vmlinux tools/bpf/bpftool/vmlinux.h
  install -Dt "$builddir/kernel" -m644 kernel/Makefile
  install -Dt "$builddir/arch/x86" -m644 arch/x86/Makefile
  cp -t "$builddir" -a scripts
  ln -srt "$builddir" "$builddir/scripts/gdb/vmlinux-gdb.py"

  install -Dt "$builddir/tools/objtool" tools/objtool/objtool
  install -Dt "$builddir/tools/bpf/resolve_btfids" tools/bpf/resolve_btfids/resolve_btfids

  echo "Installing headers..."
  cp -t "$builddir" -a include
  cp -t "$builddir/arch/x86" -a arch/x86/include
  install -Dt "$builddir/arch/x86/kernel" -m644 arch/x86/kernel/asm-offsets.s

  install -Dt "$builddir/drivers/md" -m644 drivers/md/*.h
  install -Dt "$builddir/net/mac80211" -m644 net/mac80211/*.h
  install -Dt "$builddir/drivers/media/i2c" -m644 drivers/media/i2c/msp3400-driver.h
  install -Dt "$builddir/drivers/media/usb/dvb-usb" -m644 drivers/media/usb/dvb-usb/*.h
  install -Dt "$builddir/drivers/media/dvb-frontends" -m644 drivers/media/dvb-frontends/*.h
  install -Dt "$builddir/drivers/media/tuners" -m644 drivers/media/tuners/*.h
  install -Dt "$builddir/drivers/iio/common/hid-sensors" -m644 drivers/iio/common/hid-sensors/*.h

  echo "Installing KConfig files..."
  find . -name 'Kconfig*' -exec install -Dm644 {} "$builddir/{}" \;

  echo "Installing Rust files..."
  install -Dt "$builddir/rust" -m644 rust/*.rmeta
  install -Dt "$builddir/rust" rust/*.so

  echo "Installing unstripped VDSO..."
  make INSTALL_MOD_PATH="$pkgdir/usr" vdso_install link=

  echo "Removing unneeded architectures..."
  local arch
  for arch in "$builddir"/arch/*/; do
    [[ $arch = */x86/ ]] && continue
    rm -r "$arch"
  done

  echo "Removing documentation..."
  rm -r "$builddir/Documentation"

  echo "Removing broken symlinks..."
  find -L "$builddir" -type l -printf 'Removing %P\n' -delete

  echo "Removing loose objects..."
  find "$builddir" -type f -name '*.o' -printf 'Removing %P\n' -delete

  echo "Stripping build tools..."
  local file
  while read -rd '' file; do
    case "$(file -Sib "$file")" in
      application/x-sharedlib\;*)      strip -v $STRIP_SHARED "$file" ;;
      application/x-archive\;*)        strip -v $STRIP_STATIC "$file" ;;
      application/x-executable\;*)     strip -v $STRIP_BINARIES "$file" ;;
      application/x-pie-executable\;*) strip -v $STRIP_SHARED "$file" ;;
    esac
  done < <(find "$builddir" -type f -perm -u+x ! -name vmlinux -print0)

  echo "Stripping vmlinux..."
  strip -v $STRIP_STATIC "$builddir/vmlinux"

  echo "Adding symlink..."
  mkdir -p "$pkgdir/usr/src"
  ln -sr "$builddir" "$pkgdir/usr/src/$pkgbase"
}

pkgname=(
  "$pkgbase"
  "$pkgbase-headers"
)
for _p in "${pkgname[@]}"; do
  eval "package_$_p() {
    $(declare -f "_package${_p#$pkgbase}")
    _package${_p#$pkgbase}
  }"
done
