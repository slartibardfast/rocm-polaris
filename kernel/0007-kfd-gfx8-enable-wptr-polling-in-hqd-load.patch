--- a/drivers/gpu/drm/amd/amdgpu/amdgpu_amdkfd_gfx_v8.c
+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_amdkfd_gfx_v8.c
@@ -217,6 +217,39 @@
 	if (valid_wptr)
 		WREG32(mmCP_HQD_PQ_WPTR, (wptr_val << wptr_shift) & wptr_mask);

+	if (wptr) {
+		uint32_t poll_cntl, poll_cntl_before;
+		uint32_t queue_mask = 1 << (pipe_id *
+			adev->gfx.mec.num_queue_per_pipe + queue_id);
+
+		/* Enable periodic WPTR polling from the poll address.
+		 * gfx_v8_0_mqd_commit disables EN for KMD graphics queues
+		 * (which manage WPTR via direct register writes), but KFD
+		 * compute queues with SLOT_BASED_WPTR=2 require the CP to
+		 * read WPTR from memory.  Without EN=1 the poll address
+		 * set in the MQD is ignored and CP_HQD_PQ_WPTR stays at
+		 * its initial value.
+		 */
+		poll_cntl_before = RREG32(mmCP_PQ_WPTR_POLL_CNTL);
+		poll_cntl = poll_cntl_before;
+		poll_cntl |= CP_PQ_WPTR_POLL_CNTL__EN_MASK;
+		poll_cntl &= ~CP_PQ_WPTR_POLL_CNTL__PERIOD_MASK;
+		poll_cntl |= 0x10;  /* poll period */
+		WREG32(mmCP_PQ_WPTR_POLL_CNTL, poll_cntl);
+
+		WREG32(mmCP_PQ_WPTR_POLL_CNTL1, queue_mask);
+
+		pr_info("kfd gfx8 hqd_load: pipe=%u queue=%u mask=0x%x "
+			"poll_cntl 0x%x->0x%x cntl1=0x%x "
+			"poll_addr=0x%x:%x wptr_reg=0x%x pq_control=0x%x\n",
+			pipe_id, queue_id, queue_mask,
+			poll_cntl_before, poll_cntl, queue_mask,
+			m->cp_hqd_pq_wptr_poll_addr_hi,
+			m->cp_hqd_pq_wptr_poll_addr_lo,
+			RREG32(mmCP_HQD_PQ_WPTR),
+			m->cp_hqd_pq_control);
+	}
+
 	data = REG_SET_FIELD(m->cp_hqd_active, CP_HQD_ACTIVE, ACTIVE, 1);
 	WREG32(mmCP_HQD_ACTIVE, data);

