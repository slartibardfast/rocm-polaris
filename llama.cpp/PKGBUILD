# Maintainer: David Connolly <david@connol.ly>
# Based on extra/llama.cpp PKGBUILD
#
# llama.cpp built with ROCm/HIP for gfx803 (Polaris/Fiji).
# Replaces the stock CPU-only llama.cpp package.

pkgname=llama-cpp-rocm-polaris
_upstream_pkgname=llama.cpp
pkgver=b8508
pkgrel=3
pkgdesc='LLM inference in C/C++ with ROCm GPU support (gfx803)'
arch=('x86_64')
url='https://github.com/ggml-org/llama.cpp'
license=('MIT')
depends=(
  'curl'
  'gcc-libs'
  'glibc'
  'hip-runtime-amd'
  'hipblas'
  'hsa-rocr-polaris'
  'rocblas-gfx803'
)
makedepends=(
  'cmake'
  'git'
  'rocm-toolchain'
)
provides=("llama.cpp=$pkgver")
conflicts=('llama.cpp')
source=("$_upstream_pkgname-$pkgver::git+$url.git#tag=$pkgver")
sha256sums=('SKIP')

prepare() {
  cd "$_upstream_pkgname-$pkgver"

  # Phase 15: Hand-vectorized ggml_vec_max_f32 with SSE.
  local _vech=ggml/src/ggml-cpu/vec.h
  python3 -c "
with open('$_vech') as f: s = f.read()
old = '''inline static void ggml_vec_max_f32(const int n, float * s, const float * x) {
#ifndef GGML_USE_ACCELERATE
    float max = -INFINITY;
    for (int i = 0; i < n; ++i) {
        max = MAX(max, x[i]);
    }
    *s = max;
#else
    vDSP_maxv(x, 1, s, n);
#endif
}'''
new = '''inline static void ggml_vec_max_f32(const int n, float * s, const float * x) {
#if defined(__SSE__)
    __m128 vmax = _mm_set1_ps(-INFINITY);
    int i = 0;
    for (; i + 15 < n; i += 16) {
        vmax = _mm_max_ps(vmax, _mm_loadu_ps(x + i));
        vmax = _mm_max_ps(vmax, _mm_loadu_ps(x + i + 4));
        vmax = _mm_max_ps(vmax, _mm_loadu_ps(x + i + 8));
        vmax = _mm_max_ps(vmax, _mm_loadu_ps(x + i + 12));
    }
    for (; i + 3 < n; i += 4) {
        vmax = _mm_max_ps(vmax, _mm_loadu_ps(x + i));
    }
    vmax = _mm_max_ps(vmax, _mm_shuffle_ps(vmax, vmax, _MM_SHUFFLE(2,3,0,1)));
    vmax = _mm_max_ps(vmax, _mm_movehl_ps(vmax, vmax));
    float max = _mm_cvtss_f32(vmax);
    for (; i < n; ++i) { if (x[i] > max) max = x[i]; }
    *s = max;
#elif !defined(GGML_USE_ACCELERATE)
    float max = -INFINITY;
    for (int i = 0; i < n; ++i) {
        max = MAX(max, x[i]);
    }
    *s = max;
#else
    vDSP_maxv(x, 1, s, n);
#endif
}'''
assert old in s, 'ggml_vec_max_f32 pattern not found'
s = s.replace(old, new, 1)
with open('$_vech', 'w') as f: f.write(s)
print('OK: Phase 15 SSE vec_max_f32 injected')
"

  # Phase 15: Hand-vectorized ggml_vec_argmax_f32 with SSE4.1.
  python3 -c "
with open('$_vech') as f: s = f.read()
old = '''inline static void ggml_vec_argmax_f32(const int n, int * s, const float * x) {
    float max = -INFINITY;
    int idx = 0;
    for (int i = 0; i < n; ++i) {
        max = MAX(max, x[i]);
        if (max == x[i]) { idx = i; }
    }
    *s = idx;
}'''
new = '''inline static void ggml_vec_argmax_f32(const int n, int * s, const float * x) {
#if defined(__SSE4_1__)
    __m128 vmax = _mm_set1_ps(-INFINITY);
    __m128i vidx = _mm_setzero_si128();
    __m128i vcur = _mm_setr_epi32(0, 1, 2, 3);
    const __m128i vstep = _mm_set1_epi32(4);
    int i = 0;
    for (; i + 3 < n; i += 4) {
        __m128 v = _mm_loadu_ps(x + i);
        __m128 mask = _mm_cmpgt_ps(v, vmax);
        vmax = _mm_blendv_ps(vmax, v, mask);
        vidx = (__m128i)_mm_blendv_ps((__m128)vidx, (__m128)vcur, mask);
        vcur = _mm_add_epi32(vcur, vstep);
    }
    float tmp[4]; int tmpi[4];
    _mm_storeu_ps(tmp, vmax);
    _mm_storeu_si128((__m128i*)tmpi, vidx);
    float max = tmp[0]; int idx = tmpi[0];
    for (int j = 1; j < 4; j++) { if (tmp[j] > max) { max = tmp[j]; idx = tmpi[j]; } }
    for (; i < n; ++i) { if (x[i] > max) { max = x[i]; idx = i; } }
    *s = idx;
#else
    float max = -INFINITY;
    int idx = 0;
    for (int i = 0; i < n; ++i) {
        max = MAX(max, x[i]);
        if (max == x[i]) { idx = i; }
    }
    *s = idx;
#endif
}'''
assert old in s, 'ggml_vec_argmax_f32 pattern not found'
s = s.replace(old, new, 1)
with open('$_vech', 'w') as f: f.write(s)
print('OK: Phase 15 SSE4.1 vec_argmax_f32 injected')
"

  # Phase 15: Inline fast expf for CPU softmax.
  local _ops=ggml/src/ggml-cpu/ops.cpp
  python3 -c "
with open('$_ops') as f: s = f.read()
marker = '#include <cmath>'
fast_exp = '''#include <cmath>

static inline float ggml_fast_expf(float x) {
    if (x < -88.0f) return 0.0f;
    if (x > 88.0f) return INFINITY;
    float k = roundf(x * 1.4426950408889634f);
    float r = x - k * 0.6931471805599453f;
    float p = 1.0f + r * (1.0f + r * (0.5f + r * (0.16666667f + r * 0.041666668f)));
    union { float f; int32_t i; } u; u.f = p;
    u.i += ((int32_t)k) << 23;
    return u.f;
}
'''
assert marker in s, '#include <cmath> not found in ops.cpp'
s = s.replace(marker, fast_exp, 1)
s = s.replace(
    'sum += (ggml_float) expf(sk[i02] - max);',
    'sum += (ggml_float) ggml_fast_expf(sk[i02] - max);',
)
with open('$_ops', 'w') as f: f.write(s)
print('OK: Phase 15 fast_expf for CPU softmax injected')
"
}

build() {
  export HIPCXX=/opt/rocm/lib/llvm/bin/amdclang++
  export HIP_PATH=/opt/rocm

  # Phase 15: Override Arch's -march=x86-64 with native Westmere.
  # Enables SSE4.2 + SSSE3 for CPU-side ops (sampling, graph sched).
  # -ffast-math enables auto-vectorization of reduction loops.
  export CFLAGS="${CFLAGS//-march=x86-64/-march=native} -ffast-math -fno-finite-math-only"
  export CXXFLAGS="${CXXFLAGS//-march=x86-64/-march=native} -ffast-math -fno-finite-math-only"

  local cmake_args=(
    -Wno-dev
    -S "$_upstream_pkgname-$pkgver"
    -B build
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
    -D CMAKE_SKIP_RPATH=ON
    -D GGML_HIP=ON
    -D AMDGPU_TARGETS=gfx803
    -D BUILD_SHARED_LIBS=ON
    -D GGML_NATIVE=ON
    -D LLAMA_CURL=ON
  )
  cmake "${cmake_args[@]}"
  cmake --build build -j$(nproc)
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 "$_upstream_pkgname-$pkgver/LICENSE" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
