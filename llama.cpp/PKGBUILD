# Maintainer: David Connolly <david@connol.ly>
# Based on extra/llama.cpp PKGBUILD
#
# llama.cpp built with ROCm/HIP for gfx803 (Polaris/Fiji).
# Replaces the stock CPU-only llama.cpp package.

pkgname=llama-cpp-rocm-polaris
_upstream_pkgname=llama.cpp
pkgver=b7376
pkgrel=4
pkgdesc='LLM inference in C/C++ with ROCm GPU support (gfx803)'
arch=('x86_64')
url='https://github.com/ggml-org/llama.cpp'
license=('MIT')
depends=(
  'curl'
  'gcc-libs'
  'glibc'
  'hip-runtime-amd'
  'hipblas'
  'hsa-rocr-polaris'
  'rocblas-gfx803'
)
makedepends=(
  'cmake'
  'git'
  'rocm-toolchain'
)
provides=("llama.cpp=$pkgver")
conflicts=('llama.cpp')
source=("$_upstream_pkgname-$pkgver::git+$url.git#tag=$pkgver")
sha256sums=('SKIP')

prepare() {
  cd "$_upstream_pkgname-$pkgver"

  # Phase 9 debug: Log each GPU kernel dispatch to identify hang point
  local _cuda_cu=ggml/src/ggml-cuda/ggml-cuda.cu
  sed -i '/bool ok = ggml_cuda_compute_forward/i\
                fprintf(stderr, "[GGML-GPU] node %d/%d: %s op=%s src0=%p(%s) src1=%p(%s)\\n", i, cgraph->n_nodes, node->name, ggml_op_name(node->op), node->src[0] ? node->src[0]->data : NULL, node->src[0] ? node->src[0]->name : "", node->src[1] ? node->src[1]->data : NULL, node->src[1] ? node->src[1]->name : "");\
                fflush(stderr);' "$_cuda_cu"

  # Also log after compute_forward returns to see if it completes
  sed -i 's/bool ok = ggml_cuda_compute_forward(\*cuda_ctx, node);/bool ok = ggml_cuda_compute_forward(*cuda_ctx, node);\
                fprintf(stderr, "[GGML-GPU] node %d done ok=%d\\n", i, ok); fflush(stderr);/' "$_cuda_cu"

  # Log hipDeviceSynchronize result + NOP kick before graph compute
  sed -i '/static enum ggml_status ggml_backend_cuda_graph_compute/,/ggml_cuda_set_device/ {
    /ggml_cuda_set_device/a\
    { hipError_t _err = hipDeviceSynchronize(); fprintf(stderr, "[GGML-GPU] PRE-COMPUTE sync=%d n_nodes=%d\\n", _err, cgraph->n_nodes); fflush(stderr); \
      /* Phase 9 fix: launch a tiny NOP kernel to wake the CP after sync */ \
      static bool __once = false; if (!__once) { __once = true; } else { \
        int __dummy = 0; hipMemsetAsync(&__dummy, 0, 0, cuda_ctx->stream()); \
        _err = hipStreamSynchronize(cuda_ctx->stream()); \
        fprintf(stderr, "[GGML-GPU] POST-NOP sync=%d\\n", _err); fflush(stderr); \
      } \
    }
  }' "$_cuda_cu"
}

build() {
  export HIPCXX=/opt/rocm/lib/llvm/bin/amdclang++
  export HIP_PATH=/opt/rocm

  local cmake_args=(
    -Wno-dev
    -S "$_upstream_pkgname-$pkgver"
    -B build
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
    -D CMAKE_SKIP_RPATH=ON
    -D GGML_HIP=ON
    -D AMDGPU_TARGETS=gfx803
    -D BUILD_SHARED_LIBS=ON
    -D GGML_NATIVE=OFF
    -D LLAMA_CURL=ON
  )
  cmake "${cmake_args[@]}"
  cmake --build build -j$(nproc)
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 "$_upstream_pkgname-$pkgver/LICENSE" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
