   FreeQueueMemory();
 
   if (core::g_use_interrupt_wait) {
@@ -406,13 +430,35 @@
 }
 
 uint64_t AqlQueue::LoadReadIndexAcquire() {
+  UpdateReadDispatchId();
   return atomic::Load(&amd_queue_.read_dispatch_id, std::memory_order_acquire);
 }
 
 uint64_t AqlQueue::LoadReadIndexRelaxed() {
+  UpdateReadDispatchId();
   return atomic::Load(&amd_queue_.read_dispatch_id, std::memory_order_relaxed);
 }
 
+void AqlQueue::UpdateReadDispatchId() {
+  if (!rptr_gpu_buf_) return;
+  // CP writes RPTR as dword offset that wraps at ring_size * 16.
+  // Convert to monotonic AQL dispatch index (each packet = 16 dwords).
+  uint32_t cur_dw = static_cast<uint32_t>(
+      atomic::Load(rptr_gpu_buf_, std::memory_order_acquire));
+  uint32_t prev_dw = last_rptr_dwords_;
+  if (cur_dw != prev_dw) {
+    uint32_t ring_dwords = amd_queue_.hsa_queue.size * 16;
+    uint32_t delta = (cur_dw >= prev_dw)
+                         ? (cur_dw - prev_dw)
+                         : (ring_dwords - prev_dw + cur_dw);
+    last_rptr_dwords_ = cur_dw;
+    uint64_t id = atomic::Load(&amd_queue_.read_dispatch_id,
+                               std::memory_order_relaxed);
+    atomic::Store(&amd_queue_.read_dispatch_id, id + delta / 16,
+                  std::memory_order_release);
+  }
+}
+
 uint64_t AqlQueue::LoadWriteIndexAcquire() {
   return atomic::Load(&amd_queue_.write_dispatch_id, std::memory_order_acquire);
 }
@@ -475,7 +521,21 @@
   } else {
     // Hardware doorbell supports AQL semantics.
     _mm_sfence();
-    *(signal_.hardware_doorbell_ptr) = uint64_t(value);
+    if (legacy_doorbell_) {
+      if (no_atomics_) {
+        // SLOT_BASED_WPTR=0: doorbell value directly becomes CP_HQD_PQ_WPTR.
+        // Convert AQL packet index to dword offset in ring buffer.
+        // Each AQL packet = 64 bytes = 16 dwords.  Mask wraps at ring size.
+        uint32_t wptr_mask = (amd_queue_.hsa_queue.size * 16) - 1;
+        uint32_t wptr_dwords = static_cast<uint32_t>(value * 16) & wptr_mask;
+        *(volatile uint32_t*)(signal_.hardware_doorbell_ptr) = wptr_dwords;
+      } else {
+        // SLOT_BASED_WPTR=2: doorbell is notification, value is dispatch index.
+        *(volatile uint32_t*)(signal_.hardware_doorbell_ptr) = uint32_t(value);
+      }
+    } else {
+      *(signal_.hardware_doorbell_ptr) = uint64_t(value);
+    }
     /* signal_ is allocated as uncached so we do not need read-back to flush WC */
   }
   return;
