--- a/runtime/hsa-runtime/core/inc/amd_aql_queue.h
+++ b/runtime/hsa-runtime/core/inc/amd_aql_queue.h
@@ -296,6 +296,23 @@
   // Handle of agent, which queue is attached to
   GpuAgent* agent_;
 
+  // True if gfx8 (4-byte doorbells), false for gfx9+ (8-byte doorbells)
+  bool legacy_doorbell_;
+
+  // True when platform lacks PCIe atomics (from agent)
+  bool no_atomics_;
+
+  // GPU-visible buffer for CP RPTR writes (no-atomics only).
+  // With NO_UPDATE_RPTR=0, CP writes dword offset to rptr_report_addr.
+  // We convert to monotonic dispatch ID in UpdateReadDispatchId().
+  uint64_t* rptr_gpu_buf_;
+
+  // Last seen dword offset from rptr_gpu_buf_ (for wrap-around tracking).
+  uint32_t last_rptr_dwords_;
+
+  /// @brief Convert dword RPTR from GPU buffer to amd_queue_.read_dispatch_id.
+  void UpdateReadDispatchId();
+
   // Handle of scratch memory descriptor
   ScratchInfo queue_scratch_;
 
