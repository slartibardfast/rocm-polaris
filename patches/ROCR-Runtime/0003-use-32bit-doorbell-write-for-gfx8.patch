   memset(&amd_queue_, 0, sizeof(amd_queue_));
 
+  // Allocate GPU-visible RPTR buffer for no-atomics platforms.
+  // system_allocator() returns kernarg pool memory: mapped in GPU page
+  // tables (CPU VA = GPU VA), so CP can write to rptr_report_addr.
+  rptr_gpu_buf_ = nullptr;
+  if (no_atomics_) {
+    rptr_gpu_buf_ = static_cast<uint64_t*>(
+        agent_->system_allocator()(0x1000, 0x1000, 0));
+    if (rptr_gpu_buf_ == nullptr)
+      throw AMD::hsa_exception(HSA_STATUS_ERROR_OUT_OF_RESOURCES,
+                               "RPTR GPU buffer allocation failed.\n");
+    *rptr_gpu_buf_ = 0;
+  }
+
   // Initialize and map a HW AQL queue.
   HsaQueueResource queue_rsrc = {0};
-  queue_rsrc.Queue_read_ptr_aql = (uint64_t*)&amd_queue_.read_dispatch_id;
+  queue_rsrc.Queue_read_ptr_aql =
+      rptr_gpu_buf_ ? rptr_gpu_buf_
+                    : (uint64_t*)&amd_queue_.read_dispatch_id;
 
   // Hardware write pointer supports AQL semantics.
   queue_rsrc.Queue_write_ptr_aql = (uint64_t*)&amd_queue_.write_dispatch_id;
@@ -384,6 +403,11 @@
   exception_signal_->WaitingDec();
