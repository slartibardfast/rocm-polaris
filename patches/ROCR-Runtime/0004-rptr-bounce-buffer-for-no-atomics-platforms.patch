 AqlQueue::~AqlQueue() {
+  if (no_atomics_) {
+    ScopedAcquire<KernelMutex> lock(&bounce_list_lock_);
+    auto it = std::find(bounce_queues_.begin(), bounce_queues_.end(), this);
+    if (it != bounce_queues_.end()) bounce_queues_.erase(it);
+  }
+
+  // Release any signals still held by the bounce buffer.
+  for (const auto& entry : pending_completions_) {
+    core::Signal::Convert(entry.signal)->Release();
+  }
+  pending_completions_.clear();
