+void AqlQueue::ScanNewPackets() {
+  if (!no_atomics_) return;
+
+  uint64_t write_idx = atomic::Load(&amd_queue_.write_dispatch_id,
+                                    std::memory_order_acquire);
+  if (write_idx <= last_scanned_idx_) return;
+
+  ScopedAcquire<KernelMutex> lock(&bounce_lock_);
+  // Re-check after acquiring lock.
+  write_idx = atomic::Load(&amd_queue_.write_dispatch_id,
+                           std::memory_order_acquire);
+  if (write_idx <= last_scanned_idx_) return;
+
+  const uint32_t queue_mask = amd_queue_.hsa_queue.size - 1;
+  const char* ring_base = static_cast<const char*>(amd_queue_.hsa_queue.base_address);
+
+  for (uint64_t idx = last_scanned_idx_; idx < write_idx; idx++) {
+    uint32_t slot = static_cast<uint32_t>(idx & queue_mask);
+    // AQL packets are 64 bytes.  Read header to determine packet type,
+    // then extract completion_signal from the appropriate offset.
+    const uint16_t* header_ptr = reinterpret_cast<const uint16_t*>(
+        ring_base + slot * 64);
+    uint16_t header = atomic::Load(header_ptr, std::memory_order_acquire);
+    uint8_t pkt_type = header & 0xFF;
+
+    hsa_signal_t sig = {0};
+    if (pkt_type == HSA_PACKET_TYPE_KERNEL_DISPATCH ||
+        pkt_type == HSA_PACKET_TYPE_AGENT_DISPATCH ||
+        pkt_type == HSA_PACKET_TYPE_BARRIER_AND ||
+        pkt_type == HSA_PACKET_TYPE_BARRIER_OR) {
+      // completion_signal at offset 56 for all AQL packet types
+      const hsa_signal_t* sig_ptr = reinterpret_cast<const hsa_signal_t*>(
+          ring_base + slot * 64 + 56);
+      sig = *sig_ptr;
+    }
+
+    if (bounce_debug()) {
+      fprintf(stderr, "[SCAN] idx=%lu slot=%u type=%u sig=0x%lx",
+              idx, slot, pkt_type, sig.handle);
+      if (pkt_type == HSA_PACKET_TYPE_BARRIER_AND ||
+          pkt_type == HSA_PACKET_TYPE_BARRIER_OR) {
+        const hsa_signal_t* dep = reinterpret_cast<const hsa_signal_t*>(
+            ring_base + slot * 64 + 8);  // dep_signal[0] at offset 8
+        hsa_signal_value_t dval = 0;
+        if (dep->handle) {
+          amd_signal_t* ds = reinterpret_cast<amd_signal_t*>(dep->handle);
+          dval = atomic::Load(&ds->value, std::memory_order_relaxed);
+        }
+        fprintf(stderr, " dep0=0x%lx(val=%ld)", dep->handle, dval);
+      }
+      fprintf(stderr, "\n");
+    }
+
+    if (sig.handle != 0) {
+      // Retain the signal so it cannot be freed while we hold a reference.
+      // Matched by Release() in ProcessCompletions or ~AqlQueue.
+      core::Signal::Convert(sig)->Retain();
+      pending_completions_.push_back({idx + 1, sig});
+    }
+  }
+  if (bounce_debug())
+    fprintf(stderr, "[SCAN] scanned %lu->%lu, pending=%zu\n",
+            last_scanned_idx_, write_idx, pending_completions_.size());
+  last_scanned_idx_ = write_idx;
+}
+
+void AqlQueue::ProcessCompletions() {
+  if (!no_atomics_ || pending_completions_.empty()) return;
+
+  UpdateReadDispatchId();
+
+  ScopedAcquire<KernelMutex> lock(&bounce_lock_);
+  if (pending_completions_.empty()) return;
+
+  uint64_t read_idx = atomic::Load(&amd_queue_.read_dispatch_id,
+                                   std::memory_order_acquire);
+
+  if (bounce_debug())
+    fprintf(stderr, "[COMP] read_idx=%lu pending=%zu first_complete=%lu\n",
+            read_idx, pending_completions_.size(),
+            pending_completions_.empty() ? 0 : pending_completions_[0].complete_idx);
+
+  size_t completed = 0;
+  for (const auto& entry : pending_completions_) {
+    if (read_idx >= entry.complete_idx) {
+      core::Signal* signal = core::Signal::Convert(entry.signal);
+      signal->SubRelaxed(1);
+      // Flush the signal value to DRAM so the GPU can see it.
+      amd_signal_t* ams = reinterpret_cast<amd_signal_t*>(entry.signal.handle);
+      _mm_clflush(const_cast<void*>(static_cast<volatile void*>(&ams->value)));
+      _mm_mfence();
+      signal->Release();  // matches Retain() in ScanNewPackets
+      completed++;
+    } else {
+      break;  // FIFO: remaining entries are also incomplete
+    }
+  }
+  if (completed > 0) {
+    if (bounce_debug())
+      fprintf(stderr, "[COMP] completed=%zu remaining=%zu\n",
+              completed, pending_completions_.size() - completed);
+    pending_completions_.erase(pending_completions_.begin(),
+                               pending_completions_.begin() + completed);
+  }
+}
+
+void AqlQueue::ProcessAllBounceBuffers() {
+  ScopedAcquire<KernelMutex> lock(&bounce_list_lock_);
+  for (AqlQueue* q : bounce_queues_) {
+    q->ProcessCompletions();
+  }
+}
