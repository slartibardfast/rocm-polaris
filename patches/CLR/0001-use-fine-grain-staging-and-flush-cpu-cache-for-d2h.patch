# Use fine-grain staging buffer, flush CPU cache for D2H, and drain H2D
# barrier dependencies on non-coherent platforms.
#
# On gfx8 without PCIe atomics (e.g. Polaris on Westmere Xeon):
#
# Fix 1: Staging buffer from fine-grain pool (kAtomics) — GPU L2 flushed
# by FENCE_SCOPE_SYSTEM release barrier.
#
# Fix 2: clflush staging/pinned buffers after DMA completion.
#
# Fix 3: WaitCurrent() after H2D staging to drain barrier dependencies
# that the GPU CP cannot resolve (signals decremented by CPU bounce buffer
# but CP reads them via GPU L2 cache).
#
# Signed-off-by: David Connolly <david@connol.ly>

--- a/rocclr/device/rocm/rocvirtual.cpp
+++ b/rocclr/device/rocm/rocvirtual.cpp
@@ -1850,8 +1850,11 @@
     LogError("Could not create signal for copy queue!");
     return false;
   }
-  // Create managed buffer for staging copies
-  if (!managed_buffer_.Create(Device::MemorySegment::kNoAtomics)) {
+  // Create managed buffer for staging copies.
+  // Use fine-grain pool (kAtomics) so GPU L2 is flushed by the blit kernel's
+  // FENCE_SCOPE_SYSTEM release barrier.  Coarse-grain (kNoAtomics) uses MTYPE=NC
+  // which gfx8 does not flush on system-scope release.
+  if (!managed_buffer_.Create(Device::MemorySegment::kAtomics)) {
     LogError("Could not create managed buffer for this queue!");
     return false;
   }
--- a/rocclr/device/rocm/rocblit.cpp	2026-03-13 21:54:05.172555054 +0000
+++ b/rocclr/device/rocm/rocblit.cpp	2026-03-13 21:55:45.608194826 +0000
@@ -27,6 +27,10 @@
 #include "utils/debug.hpp"
 #include <algorithm>
 
+#if defined(__x86_64__) || defined(__i386__)
+#include <x86intrin.h>
+#endif
+
 namespace amd::roc {
 DmaBlitManager::DmaBlitManager(VirtualGPU& gpu, Setup setup)
     : HostBlitManager(gpu, setup),
@@ -742,6 +746,16 @@
         if (outBuffer.pinnedMem_ == nullptr) {
           // Wait for current signal of previous rocr copy if its not pinned mem
           gpu().Barriers().WaitCurrent();
+#if defined(__x86_64__) || defined(__i386__)
+          // On non-coherent platforms, GPU writes via PCIe may not snoop CPU
+          // cache.  Flush staging buffer cache lines so memcpy sees GPU data.
+          if (!dev().info().pcie_atomics_) {
+            for (size_t off = 0; off < copysize; off += 64) {
+              _mm_clflush(reinterpret_cast<char*>(stagingBuffer) + off);
+            }
+            _mm_mfence();
+          }
+#endif
           ClPrint(amd::LOG_DETAIL_DEBUG, amd::LOG_COPY, "memcpy host dst=%p, stg buf=%p, size=%zu",
                   hostDst + copyOffset, stagingBuffer, copysize);
           memcpy(hostDst + copyOffset, stagingBuffer, copysize);
@@ -766,12 +780,27 @@
   if (amd::IS_HIP && (gpu().command() != nullptr) && gpu().command()->IsMemoryPinned()) {
     gpu().Barriers().WaitCurrent();
     gpu().command()->ReleasePinnedMemory();
+#if defined(__x86_64__) || defined(__i386__)
+    // Flush destination host buffer for pinned D2H on non-coherent platforms.
+    if (!hostToDev && !dev().info().pcie_atomics_) {
+      for (size_t off = 0; off < size; off += 64) {
+        _mm_clflush(reinterpret_cast<char*>(hostDst) + off);
+      }
+      _mm_mfence();
+    }
+#endif
   }
 
   if (!status) {
     return false;
   }
 
+  // On no-atomics platforms, drain the last active H2D signal so the next
+  // hipMemcpy call does not inherit an unresolvable barrier dependency.
+  if (hostToDev && !dev().info().pcie_atomics_) {
+    gpu().Barriers().WaitCurrent();
+  }
+
   return true;
 }
 
