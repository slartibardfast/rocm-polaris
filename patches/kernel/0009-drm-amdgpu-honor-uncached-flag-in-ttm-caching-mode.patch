# Honor AMDGPU_GEM_CREATE_UNCACHED in TTM caching mode selection
#
# On non-coherent platforms (gfx8 without ATC/IOMMU, e.g. Polaris on
# Westmere Xeon), GPU PCIe writes to system memory bypass CPU cache.
# ROCR sets AMDGPU_GEM_CREATE_UNCACHED on shared memory allocations to
# request uncached CPU mapping, but amdgpu_ttm_tt_new() only checks
# AMDGPU_GEM_CREATE_CPU_GTT_USWC — UNCACHED buffers get ttm_cached,
# so CPU reads see stale cache lines after GPU writes.
#
# Part 1: Check UNCACHED before USWC and use ttm_uncached caching mode.
# This makes shared memory CPU-uncached, ensuring GPU writes are visible
# to CPU without explicit cache flushes.
#
# Part 2: Set AMDGPU_PTE_SNOOPED for ttm_uncached system memory pages.
# GFX8/VI has no MTYPE field in PTEs — the SNOOPED bit is the only
# per-page coherency control.  GFX8's ISA has no L2 flush instruction
# (system-scope release is just s_waitcnt, acquire is L1-only
# BUFFER_WBINVL1_VOL).  The hardware relies on the SNOOPED bit to make
# GPU L2 participate in the PCIe coherency protocol.  Without SNOOPED=1,
# GPU L2 dirty lines for system memory never propagate to DRAM, causing
# silent data corruption on D2H transfers.
#
# With ttm_uncached + SNOOPED=1:
#   CPU side: UC (writes go directly to DRAM, no cache lines to flush)
#   GPU side: L2 coherent via PCIe snoop (writes reach DRAM reliably)
#
# Signed-off-by: David Connolly <david@connol.ly>

--- a/drivers/gpu/drm/amd/amdgpu/amdgpu_ttm.c
+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_ttm.c
@@ -1131,7 +1131,9 @@
 	else
 		gtt->pool_id = abo->xcp_id;

-	if (abo->flags & AMDGPU_GEM_CREATE_CPU_GTT_USWC)
+	if (abo->flags & AMDGPU_GEM_CREATE_UNCACHED)
+		caching = ttm_uncached;
+	else if (abo->flags & AMDGPU_GEM_CREATE_CPU_GTT_USWC)
 		caching = ttm_write_combined;
 	else
 		caching = ttm_cached;
@@ -1374,8 +1376,8 @@
 		    mem->mem_type == AMDGPU_PL_MMIO_REMAP)) {
 		flags |= AMDGPU_PTE_SYSTEM;

-		if (ttm && ttm->caching == ttm_cached)
+		if (ttm && ttm->caching != ttm_write_combined)
 			flags |= AMDGPU_PTE_SNOOPED;
 	}

 	if (mem && mem->mem_type == TTM_PL_VRAM &&
