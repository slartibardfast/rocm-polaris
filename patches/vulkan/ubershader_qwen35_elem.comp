// Phase 17: GCN3 Ubershader for elementwise ops (Qwen3.5 SSM layers)
//
// Replaces ~100 individual Vulkan dispatches per token with a single
// persistent dispatch that internally sequences operations using atomic
// barriers. On 5-CU Polaris 12, dispatch overhead is ~50µs each;
// atomic barriers cost ~0.5µs. This is a 100× synchronization improvement.
//
// The shader reads a command buffer describing which operations to execute
// and accesses data via VK_KHR_buffer_device_address (BDA) pointers.
//
// Workgroup count: 5 (one per CU) for maximum hardware utilization.
// Each workgroup processes its share of elements via grid-stride loop.

#version 450

#extension GL_EXT_buffer_reference : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#extension GL_EXT_control_flow_attributes : enable

// BDA buffer references for typed pointer access
layout(buffer_reference, std430, buffer_reference_align = 4) buffer FloatBuf { float d[]; };

// Op type enum
const uint OP_ADD       = 0;
const uint OP_MUL       = 1;
const uint OP_SCALE     = 2;
const uint OP_SILU      = 3;
const uint OP_SIGMOID   = 4;
const uint OP_CPY       = 5;
const uint OP_CONT      = 6;
const uint OP_SWIGLU    = 7;  // silu(src0) * src1
const uint OP_GATE_PREP = 8;  // softplus(src0 + src1[i%p0]) * src2[i%p0]

// Command structure — 64 bytes, aligned
struct UberCmd {
    uint op_type;          // OP_* enum
    uint ne;               // number of elements
    uint64_t src0_addr;    // BDA pointer to source 0
    uint64_t src1_addr;    // BDA pointer to source 1 (or 0 if unused)
    uint64_t src2_addr;    // BDA pointer to source 2 (or 0 if unused)
    uint64_t dst_addr;     // BDA pointer to destination
    uint params[2];        // op-specific: params[0] = float-as-uint for SCALE,
                           //              params[0] = num_v_heads for GATE_PREP
};

layout(binding = 0) readonly buffer CmdBuf {
    UberCmd cmds[];
};

layout(binding = 1) coherent buffer BarrierBuf {
    uint counters[];
};

layout(push_constant) uniform PushConstants {
    uint num_cmds;
    uint num_wgs;
};

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

void global_barrier(uint step) {
    // Ensure all memory writes from this workgroup are visible
    memoryBarrierBuffer();

    // One thread per workgroup signals arrival
    if (gl_LocalInvocationID.x == 0) {
        atomicAdd(counters[step], 1u);
        // Spin until all workgroups arrive
        // With 5 WGs: 5 atomic adds + 4 spins = ~500 cycles = 0.5µs
        while (atomicOr(counters[step], 0u) < num_wgs) {
            // busy-wait — GCN3 s_sleep or nop would be nice but
            // GLSL has no yield primitive. The spin is short (4 iterations max).
        }
    }
    // Synchronize all threads within the workgroup
    barrier();
    // Ensure subsequent reads see all writes from other workgroups
    memoryBarrierBuffer();
}

void main() {
    const uint wg_id = gl_WorkGroupID.x;
    const uint tid = gl_LocalInvocationID.x;
    const uint global_stride = num_wgs * gl_WorkGroupSize.x;
    const uint global_start = wg_id * gl_WorkGroupSize.x + tid;

    for (uint cmd_idx = 0; cmd_idx < num_cmds; cmd_idx++) {
        UberCmd cmd = cmds[cmd_idx];
        const uint ne = cmd.ne;

        switch (cmd.op_type) {
        case OP_ADD: {
            FloatBuf s0 = FloatBuf(cmd.src0_addr);
            FloatBuf s1 = FloatBuf(cmd.src1_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            for (uint i = global_start; i < ne; i += global_stride)
                dst.d[i] = s0.d[i] + s1.d[i];
        } break;

        case OP_MUL: {
            FloatBuf s0 = FloatBuf(cmd.src0_addr);
            FloatBuf s1 = FloatBuf(cmd.src1_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            for (uint i = global_start; i < ne; i += global_stride)
                dst.d[i] = s0.d[i] * s1.d[i];
        } break;

        case OP_SCALE: {
            FloatBuf s0 = FloatBuf(cmd.src0_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            float scale_val = uintBitsToFloat(cmd.params[0]);
            for (uint i = global_start; i < ne; i += global_stride)
                dst.d[i] = s0.d[i] * scale_val;
        } break;

        case OP_SILU: {
            FloatBuf s0 = FloatBuf(cmd.src0_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            for (uint i = global_start; i < ne; i += global_stride) {
                float x = s0.d[i];
                dst.d[i] = x / (1.0 + exp(-x));
            }
        } break;

        case OP_SIGMOID: {
            FloatBuf s0 = FloatBuf(cmd.src0_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            for (uint i = global_start; i < ne; i += global_stride) {
                dst.d[i] = 1.0 / (1.0 + exp(-s0.d[i]));
            }
        } break;

        case OP_CPY:
        case OP_CONT: {
            FloatBuf s0 = FloatBuf(cmd.src0_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            for (uint i = global_start; i < ne; i += global_stride)
                dst.d[i] = s0.d[i];
        } break;

        case OP_SWIGLU: {
            // swiglu(gate, up) = silu(gate) * up
            FloatBuf gate = FloatBuf(cmd.src0_addr);
            FloatBuf up = FloatBuf(cmd.src1_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            for (uint i = global_start; i < ne; i += global_stride) {
                float g = gate.d[i];
                float silu_g = g / (1.0 + exp(-g));
                dst.d[i] = silu_g * up.d[i];
            }
        } break;

        case OP_GATE_PREP: {
            // gate_prep(alpha, dt_bias, ssm_a) =
            //   softplus(alpha[i] + dt_bias[i % nhv]) * ssm_a[i % nhv]
            FloatBuf alpha = FloatBuf(cmd.src0_addr);
            FloatBuf dt_bias = FloatBuf(cmd.src1_addr);
            FloatBuf ssm_a = FloatBuf(cmd.src2_addr);
            FloatBuf dst = FloatBuf(cmd.dst_addr);
            uint nhv = cmd.params[0];  // num_v_heads
            for (uint i = global_start; i < ne; i += global_stride) {
                uint h = i % nhv;
                float x = alpha.d[i] + dt_bias.d[h];
                float sp = (x > 20.0) ? x : log(1.0 + exp(x));
                dst.d[i] = sp * ssm_a.d[h];
            }
        } break;

        default:
            break;
        }

        // Synchronize all workgroups before next command
        global_barrier(cmd_idx);
    }
}
