diff --git a/ggml/src/ggml-vulkan/vulkan-shaders/fused_dual_l2_norm.comp b/ggml/src/ggml-vulkan/vulkan-shaders/fused_dual_l2_norm.comp
new file mode 100644
index 0000000000..609a94e6de
--- /dev/null
+++ b/ggml/src/ggml-vulkan/vulkan-shaders/fused_dual_l2_norm.comp
@@ -0,0 +1,70 @@
+// Phase 16: Fused dual L2 normalization for Qwen3.5 SSM layers.
+// Combines: l2_norm(q) + l2_norm(k) into one dispatch.
+// Eliminates 1 dispatch boundary per SSM layer (36 total → 18).
+//
+// Both q and k have the same dimensions and are L2-normalized
+// independently. Fusing avoids an inter-dispatch cache flush.
+//
+// Inputs:
+//   binding 0: q [head_k_dim, num_heads, n_seq_tokens, n_seqs]
+//   binding 1: k [head_k_dim, num_heads, n_seq_tokens, n_seqs]
+//   binding 2: q_out (same shape)
+//   binding 3: k_out (same shape)
+//
+// Compute: q_out = q / ||q||, k_out = k / ||k|| (per-vector L2 norm)
+
+#version 450
+
+#extension GL_EXT_control_flow_attributes : enable
+
+layout(constant_id = 0) const uint VEC_DIM = 128;
+
+layout(local_size_x_id = 0, local_size_y = 1, local_size_z = 1) in;
+
+layout(binding = 0) readonly  buffer QIn  { float data_q_in[];  };
+layout(binding = 1) readonly  buffer KIn  { float data_k_in[];  };
+layout(binding = 2) writeonly buffer QOut { float data_q_out[]; };
+layout(binding = 3) writeonly buffer KOut { float data_k_out[]; };
+
+layout(push_constant) uniform PushConstants {
+    uint ne;       // total elements per tensor
+    uint vec_dim;  // elements per L2 norm group
+    float eps;     // epsilon for numerical stability
+};
+
+shared float sq[256];
+shared float sk[256];
+
+void main() {
+    const uint tid = gl_LocalInvocationID.x;
+    const uint group_id = gl_WorkGroupID.x;
+    const uint base = group_id * vec_dim;
+
+    if (base >= ne) return;
+
+    // Compute sum of squares for both q and k
+    float sum_q = 0.0, sum_k = 0.0;
+    for (uint i = tid; i < vec_dim; i += gl_WorkGroupSize.x) {
+        float qv = data_q_in[base + i];
+        float kv = data_k_in[base + i];
+        sum_q += qv * qv;
+        sum_k += kv * kv;
+    }
+    sq[tid] = sum_q;
+    sk[tid] = sum_k;
+    barrier();
+
+    for (uint s = gl_WorkGroupSize.x / 2; s > 0; s >>= 1) {
+        if (tid < s) { sq[tid] += sq[tid + s]; sk[tid] += sk[tid + s]; }
+        barrier();
+    }
+
+    float inv_norm_q = 1.0 / sqrt(sq[0] + eps);
+    float inv_norm_k = 1.0 / sqrt(sk[0] + eps);
+
+    // Normalize both vectors
+    for (uint i = tid; i < vec_dim; i += gl_WorkGroupSize.x) {
+        data_q_out[base + i] = data_q_in[base + i] * inv_norm_q;
+        data_k_out[base + i] = data_k_in[base + i] * inv_norm_k;
+    }
+}
diff --git a/ggml/src/ggml-vulkan/vulkan-shaders/fused_gate_prep.comp b/ggml/src/ggml-vulkan/vulkan-shaders/fused_gate_prep.comp
new file mode 100644
index 0000000000..ca739131e4
--- /dev/null
+++ b/ggml/src/ggml-vulkan/vulkan-shaders/fused_gate_prep.comp
@@ -0,0 +1,38 @@
+// Phase 16: Fused gate preparation for Qwen3.5 SSM layers.
+// Combines: add(alpha, dt_bias) + softplus + mul(ssm_a) into one dispatch.
+// Eliminates 2 dispatch boundaries per SSM layer (54 total → 18).
+//
+// Inputs:
+//   binding 0: alpha [num_v_heads, n_seq_tokens, n_seqs] — from matmul
+//   binding 1: dt_bias [num_v_heads] — per-head bias (model weight)
+//   binding 2: ssm_a [num_v_heads] — per-head scale (model weight, typically negative)
+//   binding 3: output [num_v_heads, n_seq_tokens, n_seqs]
+//
+// Compute: output[i] = softplus(alpha[i] + dt_bias[i % num_v_heads]) * ssm_a[i % num_v_heads]
+// Where softplus(x) = x > 20 ? x : log(1 + exp(x))
+
+#version 450
+
+#extension GL_EXT_control_flow_attributes : enable
+
+layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
+
+layout(binding = 0) readonly  buffer Alpha  { float data_alpha[]; };
+layout(binding = 1) readonly  buffer DtBias { float data_dt[];    };
+layout(binding = 2) readonly  buffer SsmA   { float data_a[];     };
+layout(binding = 3) writeonly buffer Dst    { float data_dst[];   };
+
+layout(push_constant) uniform PushConstants {
+    uint ne;           // total elements
+    uint num_v_heads;  // head count for bias/scale indexing
+};
+
+void main() {
+    const uint i = gl_GlobalInvocationID.x;
+    if (i >= ne) return;
+
+    const uint head_idx = i % num_v_heads;
+    const float x = data_alpha[i] + data_dt[head_idx];
+    const float sp = (x > 20.0) ? x : log(1.0 + exp(x));
+    data_dst[i] = sp * data_a[head_idx];
+}
diff --git a/ggml/src/ggml-vulkan/vulkan-shaders/fused_gated_norm.comp b/ggml/src/ggml-vulkan/vulkan-shaders/fused_gated_norm.comp
new file mode 100644
index 0000000000..5d29e6a1aa
--- /dev/null
+++ b/ggml/src/ggml-vulkan/vulkan-shaders/fused_gated_norm.comp
@@ -0,0 +1,71 @@
+// Phase 16: Fused gated normalization for Qwen3.5 SSM layers.
+// Combines: rms_norm(input, weights) * silu(gate) into one dispatch.
+// Eliminates 2 dispatch boundaries per SSM layer (54 total → 18).
+//
+// Inputs:
+//   binding 0: input [head_v_dim, num_v_heads, n_seq_tokens, n_seqs]
+//   binding 1: norm_weights [head_v_dim] — RMS norm scale
+//   binding 2: gate [head_v_dim, num_v_heads, n_seq_tokens, n_seqs]
+//   binding 3: output [head_v_dim, num_v_heads, n_seq_tokens, n_seqs]
+//
+// Compute: output[i] = rms_norm(input, weights)[i] * silu(gate[i])
+// Where rms_norm(x) = x / sqrt(mean(x^2) + eps) * weight
+//       silu(x) = x / (1 + exp(-x))
+//
+// Each workgroup handles one [head_v_dim] vector — computes the RMS
+// reduction, normalizes, and multiplies by silu(gate) in one pass.
+
+#version 450
+
+#extension GL_EXT_control_flow_attributes : enable
+
+layout(constant_id = 0) const uint HEAD_DIM = 128;
+
+layout(local_size_x_id = 0, local_size_y = 1, local_size_z = 1) in;
+
+layout(binding = 0) readonly  buffer Input   { float data_in[];   };
+layout(binding = 1) readonly  buffer Weights { float data_w[];    };
+layout(binding = 2) readonly  buffer Gate    { float data_gate[]; };
+layout(binding = 3) writeonly buffer Dst     { float data_dst[];  };
+
+layout(push_constant) uniform PushConstants {
+    uint ne;        // total elements
+    uint head_dim;  // elements per norm group
+    float eps;      // RMS norm epsilon
+};
+
+shared float sdata[256];  // for reduction
+
+void main() {
+    const uint tid = gl_LocalInvocationID.x;
+    const uint group_id = gl_WorkGroupID.x;
+    const uint base = group_id * head_dim;
+
+    if (base >= ne) return;
+
+    // Step 1: Compute sum of squares for RMS norm
+    float sum_sq = 0.0;
+    for (uint i = tid; i < head_dim; i += gl_WorkGroupSize.x) {
+        float v = data_in[base + i];
+        sum_sq += v * v;
+    }
+    sdata[tid] = sum_sq;
+    barrier();
+
+    // Tree reduction
+    for (uint s = gl_WorkGroupSize.x / 2; s > 0; s >>= 1) {
+        if (tid < s) sdata[tid] += sdata[tid + s];
+        barrier();
+    }
+
+    float rms = sqrt(sdata[0] / float(head_dim) + eps);
+    float inv_rms = 1.0 / rms;
+
+    // Step 2: Normalize, scale by weight, multiply by silu(gate)
+    for (uint i = tid; i < head_dim; i += gl_WorkGroupSize.x) {
+        float normed = data_in[base + i] * inv_rms * data_w[i % head_dim];
+        float g = data_gate[base + i];
+        float silu_g = g / (1.0 + exp(-g));
+        data_dst[base + i] = normed * silu_g;
+    }
+}
