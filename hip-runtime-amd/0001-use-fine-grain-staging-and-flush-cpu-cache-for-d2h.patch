# Use fine-grain staging buffer and flush CPU cache for D2H on non-coherent platforms
#
# Fix 1: Fine-grain staging pool (kAtomics) for GPU L2 flush on gfx8
# Fix 2: CPU cache flush after GPU writes to system memory
# Fix 3: Force cpu_wait_for_signal_ on no-atomics platforms
# Fix 4: Disable pinned host memory path on no-atomics platforms
#
# Signed-off-by: David Connolly <david@connol.ly>

--- a/rocclr/device/rocm/rocvirtual.cpp
+++ b/rocclr/device/rocm/rocvirtual.cpp
@@ -1850,8 +1850,11 @@
     LogError("Could not create signal for copy queue!");
     return false;
   }
-  // Create managed buffer for staging copies
-  if (!managed_buffer_.Create(Device::MemorySegment::kNoAtomics)) {
+  // Create managed buffer for staging copies.
+  // Use fine-grain pool (kAtomics) so GPU L2 is flushed by the blit kernel's
+  // FENCE_SCOPE_SYSTEM release barrier.  Coarse-grain (kNoAtomics) uses MTYPE=NC
+  // which gfx8 does not flush on system-scope release.
+  if (!managed_buffer_.Create(Device::MemorySegment::kAtomics)) {
     LogError("Could not create managed buffer for this queue!");
     return false;
   }
