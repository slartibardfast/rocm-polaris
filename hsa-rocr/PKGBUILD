# Maintainer: David Connolly <david@connol.ly>
# Based on Arch's hsa-rocr PKGBUILD by Torsten Keßler and Christian Heusel
#
# Patches ROCR-Runtime to accept DoorbellType 1 (pre-Vega/GCN 1.2) GPUs.
# Without this patch, hsa_init() rejects gfx801/802/803 with HSA_STATUS_ERROR.

pkgname=hsa-rocr-polaris
_pkgname=hsa-rocr
pkgver=7.2.0
pkgrel=17
pkgdesc='HSA Runtime API and runtime for ROCm (with GCN 1.2/gfx8 support)'
arch=('x86_64')
url='https://github.com/ROCm/rocm-systems'
license=('NCSA')
depends=('rocm-core' 'glibc' 'gcc-libs' 'numactl' 'pciutils' 'libelf' 'libdrm'
         'rocm-device-libs' 'rocprofiler-register')
provides=("hsa-rocr=$pkgver" "hsakmt-roct=$pkgver")
conflicts=('hsa-rocr' 'hsakmt-roct')
replaces=('hsa-rocr' 'hsakmt-roct')
makedepends=('cmake' 'rocm-llvm' 'xxd')
source=("rocm-${pkgver}.tar.gz::$url/archive/rocm-$pkgver.tar.gz"
        '0001-allow-doorbell-type-1-for-gfx8.patch'
        '0002-image-runtime-tolerate-init-failure.patch'
        '0003-use-32bit-doorbell-write-for-gfx8.patch'
        '0004-rptr-bounce-buffer-for-no-atomics-platforms.patch'
        '0005-flush-cpu-cache-after-gpu-writes-to-system-memory.patch')
sha256sums=('728ea7e9bf16e6ed217a0fd1a8c9afaba2dae2e7908fa4e27201e67c803c5638'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')
_dirname="$(basename "$url")-rocm-$pkgver"/projects/rocr-runtime/
options=(!lto)

prepare() {
  cd "$_dirname"
  patch -Np1 -i "$srcdir/0001-allow-doorbell-type-1-for-gfx8.patch"
  patch -Np1 -i "$srcdir/0002-image-runtime-tolerate-init-failure.patch"
  patch -Np1 -i "$srcdir/0003-use-32bit-doorbell-write-for-gfx8.patch"
  patch -Np1 -i "$srcdir/0004-rptr-bounce-buffer-for-no-atomics-platforms.patch"
  patch -Np1 -i "$srcdir/0005-flush-cpu-cache-after-gpu-writes-to-system-memory.patch"

  # Phase 6a: CPU-wait dep_signals in BlitKernel instead of AQL barriers.
  # On no-atomics platforms, the CP goes idle after an unsatisfied barrier
  # dep and cannot be woken (SLOT_BASED_WPTR=0, no DOORBELL_HIT for same
  # WPTR).  CPU-waiting eliminates ALL barrier packets from blit copies.
  local _blit=runtime/hsa-runtime/core/runtime/amd_blit_kernel.cpp
  cat > /tmp/_blit_cpuwait.c << 'INJECT'
  // No-atomics: CPU-wait for dep signals instead of AQL barrier packets.
  // The CP goes idle after unsatisfied barrier deps with SLOT_BASED_WPTR=0.
  if (agent_->device_type() == core::Agent::kAmdGpuDevice &&
      static_cast<const AMD::GpuAgent*>(agent_)->NoPlatformAtomics() &&
      !dep_signals.empty()) {
    for (auto* sig : dep_signals) {
      while (sig->LoadRelaxed() > 0) { os::YieldThread(); }
    }
    dep_signals.clear();
  }
INJECT
  sed -i '/const uint32_t num_barrier_packet/i\
' "$_blit"
  sed -i '/const uint32_t num_barrier_packet/{
    r /tmp/_blit_cpuwait.c
  }' "$_blit"

  # Phase 6c: Re-enable interrupt-based signal wait.
  local _rt=runtime/hsa-runtime/core/runtime/runtime.cpp
  sed -i '/g_use_interrupt_wait = false;/d' "$_rt"
  local _isig=runtime/hsa-runtime/core/runtime/interrupt_signal.cpp
  sed -i '/#include "core\/inc\/interrupt_signal.h"/a\
#include "core/inc/amd_aql_queue.h"' "$_isig"
  sed -i 's|int64_t value = atomic::Load(\&signal_.value, std::memory_order_relaxed);|int64_t value = atomic::Load(\&signal_.value, std::memory_order_relaxed);\
    AMD::AqlQueue::ProcessAllBounceBuffers();\
    value = atomic::Load(\&signal_.value, std::memory_order_relaxed);|' "$_isig"

  # Phase 7b: Uncached shared memory for non-coherent platforms.
  # On platforms without PCIe atomics, GPU writes bypass CPU cache.
  # Map GPU->CPU shared memory as UC so CPU reads go straight to DRAM.

  # 7b-1: UC RPTR bounce buffer.  Replace flags=0 with AllocateUncached.
  local _aq=runtime/hsa-runtime/core/runtime/amd_aql_queue.cpp
  sed -i 's|agent_->system_allocator()(0x1000, 0x1000, 0)|agent_->system_allocator()(0x1000, 0x1000, core::MemoryRegion::AllocateUncached)|' "$_aq"

  # 7b-2: Remove clflush+mfence from UpdateReadDispatchId (UC makes them unnecessary).
  sed -i '/FlushCpuCache(rptr_gpu_buf_/d' "$_aq"
  sed -i '/CLFLUSH is not ordered/d' "$_aq"
  sed -i '/Fence ensures the invalidation/d' "$_aq"
  sed -i '/_mm_mfence();/d' "$_aq"

  # 7b-3: UC signal pool.  Add AllocateUncached to signal block allocations.
  local _sig=runtime/hsa-runtime/core/runtime/signal.cpp
  sed -i 's,core::MemoryRegion::AllocateNonPaged\, 0),core::MemoryRegion::AllocateNonPaged | core::MemoryRegion::AllocateUncached\, 0),g' "$_sig"

  # 7e: UC all CPU->GPU shared memory in the blit data path.
  # On no-atomics platforms, CPU WB-cached writes may not reach DRAM
  # before the GPU reads via PCIe.  Make every region UC.
  local _bk=runtime/hsa-runtime/core/runtime/amd_blit_kernel.cpp
  local _ga=runtime/hsa-runtime/core/runtime/amd_gpu_agent.cpp

  # 7e-1: Blit kernarg pool (src/dst/size args read by blit kernel).
  sed -i 's|16, core::MemoryRegion::AllocateNoFlags)|16, core::MemoryRegion::AllocateUncached)|' "$_bk"

  # 7e-2: AQL ring buffer (packets read by CP).  Target the system_allocator
  #        path only (line after "} else {"), not the coarsegrain path.
  sed -i '/ring_buf_ = agent_->system_allocator/,/AllocateExecutable);/{
    s,AllocateExecutable);,AllocateExecutable | core::MemoryRegion::AllocateUncached);,
  }' "$_aq"

  # 7e-3: Blit kernel code object (instruction fetch by GPU).
  sed -i 's,AllocateExecutableBlitKernelObject),AllocateExecutableBlitKernelObject | core::MemoryRegion::AllocateUncached),' "$_ga"

  # 7e-4: PM4 indirect buffer (icache invalidation commands).
  sed -i 's,pm4_ib_size_b_\, 0x1000\, core::MemoryRegion::AllocateExecutable),pm4_ib_size_b_\, 0x1000\, core::MemoryRegion::AllocateExecutable | core::MemoryRegion::AllocateUncached),' "$_aq"

  # Phase 7h: HDP flush after AQL ring buffer write on no-atomics.
  # CPU writes the AQL packet to the ring buffer (system memory).
  # GPU L2 may retain stale packet data from a previous dispatch at the
  # same ring slot.  HDP flush invalidates GPU L2, ensuring the CP reads
  # the fresh packet.  Insert after the AQL packet write, before doorbell.
  #
  # HDP_flush_ is protected on GpuAgent.  Add a public accessor.
  local _agent_h=runtime/hsa-runtime/core/inc/amd_gpu_agent.h
  sed -i '/NoPlatformAtomics/a\
\
  \/\/ Phase 7h: public accessor for HDP flush register\
  __forceinline uint32_t* HdpFlushCntl() const { return HDP_flush_.HDP_MEM_FLUSH_CNTL; }' "$_agent_h"

  # HDP flush at TWO points in StoreRelaxed:
  # 1. BEFORE the sfence (before ring buffer write) — invalidates stale L2
  # 2. AFTER the ring buffer write, before doorbell — flushes new data
  # Both with posting read for synchronous completion.
  sed -i '/_mm_sfence();/{
    /Hardware doorbell/!{
      i\
    // Phase 7h: HDP flush BEFORE ring buffer write — invalidate stale L2.\
    if (no_atomics_ \&\& agent_->HdpFlushCntl()) {\
      *agent_->HdpFlushCntl() = 1u;\
      volatile uint32_t dummy = *agent_->HdpFlushCntl();\
      (void)dummy;\
    }
    }
  }' "$_aq"
  sed -i '/Hardware doorbell supports AQL semantics/i\
    // Phase 7h: HDP flush AFTER ring buffer write, before doorbell.\
    if (no_atomics_ \&\& agent_->HdpFlushCntl()) {\
      *agent_->HdpFlushCntl() = 1u;\
      volatile uint32_t dummy = *agent_->HdpFlushCntl();\
      (void)dummy;\
    }' "$_aq"

  # Phase 7f (ACQUIRE_MEM L2 WB hack): REMOVED.
  # Root cause was SNOOPED=0 in GPU PTE, not missing L2 flush.
  # Fixed in kernel patch 0009 (ttm_uncached + SNOOPED=1).
}

build() {
  local cmake_args=(
    -Wno-dev
    -S "$_dirname"
    -B build
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/opt/rocm
    -D CMAKE_PREFIX_PATH=/opt/rocm
    -D CMAKE_CXX_FLAGS="$CXXFLAGS -DNDEBUG"
    -DBUILD_SHARED_LIBS=ON)
  cmake "${cmake_args[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$_dirname/LICENSE.txt" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
