# Maintainer: David Connolly <david@connol.ly>
# Based on Arch's hsa-rocr PKGBUILD by Torsten Keßler and Christian Heusel
#
# Patches ROCR-Runtime to accept DoorbellType 1 (pre-Vega/GCN 1.2) GPUs.
# Without this patch, hsa_init() rejects gfx801/802/803 with HSA_STATUS_ERROR.

pkgname=hsa-rocr-polaris
_pkgname=hsa-rocr
pkgver=7.2.0
pkgrel=9
pkgdesc='HSA Runtime API and runtime for ROCm (with GCN 1.2/gfx8 support)'
arch=('x86_64')
url='https://github.com/ROCm/rocm-systems'
license=('NCSA')
depends=('rocm-core' 'glibc' 'gcc-libs' 'numactl' 'pciutils' 'libelf' 'libdrm'
         'rocm-device-libs' 'rocprofiler-register')
provides=("hsa-rocr=$pkgver" "hsakmt-roct=$pkgver")
conflicts=('hsa-rocr' 'hsakmt-roct')
replaces=('hsa-rocr' 'hsakmt-roct')
makedepends=('cmake' 'rocm-llvm' 'xxd')
source=("rocm-${pkgver}.tar.gz::$url/archive/rocm-$pkgver.tar.gz"
        '0001-allow-doorbell-type-1-for-gfx8.patch'
        '0002-image-runtime-tolerate-init-failure.patch'
        '0003-use-32bit-doorbell-write-for-gfx8.patch'
        '0004-rptr-bounce-buffer-for-no-atomics-platforms.patch'
        '0005-flush-cpu-cache-after-gpu-writes-to-system-memory.patch')
sha256sums=('728ea7e9bf16e6ed217a0fd1a8c9afaba2dae2e7908fa4e27201e67c803c5638'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')
_dirname="$(basename "$url")-rocm-$pkgver"/projects/rocr-runtime/
options=(!lto)

prepare() {
  cd "$_dirname"
  patch -Np1 -i "$srcdir/0001-allow-doorbell-type-1-for-gfx8.patch"
  patch -Np1 -i "$srcdir/0002-image-runtime-tolerate-init-failure.patch"
  patch -Np1 -i "$srcdir/0003-use-32bit-doorbell-write-for-gfx8.patch"
  patch -Np1 -i "$srcdir/0004-rptr-bounce-buffer-for-no-atomics-platforms.patch"
  patch -Np1 -i "$srcdir/0005-flush-cpu-cache-after-gpu-writes-to-system-memory.patch"

  # Debug: inject RPTR logging into UpdateReadDispatchId
  local _aql=runtime/hsa-runtime/core/runtime/amd_aql_queue.cpp
  python3 -c "
import re, sys
f=open('$_aql','r'); t=f.read(); f.close()
# Insert debug block after 'last_rptr_dwords_ = cur_dw;'
old='last_rptr_dwords_ = cur_dw;'
new=old+'''
    { static int _bd=-1;
      if(_bd<0){const char*e=getenv(\"ROCR_BOUNCE_DEBUG\");_bd=e&&e[0]=='1';}
      if(_bd)fprintf(stderr,\"[RPTR] q=%p cur=%u prev=%u pkts=%u rid=%lu wid=%lu\\\\n\",
        this,cur_dw,prev_dw,delta/16,
        atomic::Load(&amd_queue_.read_dispatch_id,std::memory_order_relaxed),
        atomic::Load(&amd_queue_.write_dispatch_id,std::memory_order_relaxed));
    }'''
t=t.replace(old,new,1)
f=open('$_aql','w'); f.write(t); f.close()
print('Injected RPTR debug into',sys.argv[0] if len(sys.argv)>0 else '_aql')
"
}

build() {
  local cmake_args=(
    -Wno-dev
    -S "$_dirname"
    -B build
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/opt/rocm
    -D CMAKE_PREFIX_PATH=/opt/rocm
    -D CMAKE_CXX_FLAGS="$CXXFLAGS -DNDEBUG"
    -DBUILD_SHARED_LIBS=ON)
  cmake "${cmake_args[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$_dirname/LICENSE.txt" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
