# Maintainer: David Connolly <david@connol.ly>
# Based on Arch's hsa-rocr PKGBUILD by Torsten Keßler and Christian Heusel
#
# Patches ROCR-Runtime to accept DoorbellType 1 (pre-Vega/GCN 1.2) GPUs.
# Without this patch, hsa_init() rejects gfx801/802/803 with HSA_STATUS_ERROR.

pkgname=hsa-rocr-polaris
_pkgname=hsa-rocr
pkgver=7.2.0
pkgrel=25
pkgdesc='HSA Runtime API and runtime for ROCm (with GCN 1.2/gfx8 support)'
arch=('x86_64')
url='https://github.com/ROCm/rocm-systems'
license=('NCSA')
depends=('rocm-core' 'glibc' 'gcc-libs' 'numactl' 'pciutils' 'libelf' 'libdrm'
         'rocm-device-libs' 'rocprofiler-register')
provides=("hsa-rocr=$pkgver" "hsakmt-roct=$pkgver")
conflicts=('hsa-rocr' 'hsakmt-roct')
replaces=('hsa-rocr' 'hsakmt-roct')
makedepends=('cmake' 'rocm-llvm' 'xxd')
source=("rocm-${pkgver}.tar.gz::$url/archive/rocm-$pkgver.tar.gz"
        '0001-allow-doorbell-type-1-for-gfx8.patch'
        '0002-image-runtime-tolerate-init-failure.patch'
        '0003-use-32bit-doorbell-write-for-gfx8.patch'
        '0004-rptr-bounce-buffer-for-no-atomics-platforms.patch'
        '0005-flush-cpu-cache-after-gpu-writes-to-system-memory.patch')
sha256sums=('728ea7e9bf16e6ed217a0fd1a8c9afaba2dae2e7908fa4e27201e67c803c5638'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')
_dirname="$(basename "$url")-rocm-$pkgver"/projects/rocr-runtime/
options=(!lto)

prepare() {
  cd "$_dirname"
  patch -Np1 -i "$srcdir/0001-allow-doorbell-type-1-for-gfx8.patch"
  patch -Np1 -i "$srcdir/0002-image-runtime-tolerate-init-failure.patch"
  patch -Np1 -i "$srcdir/0003-use-32bit-doorbell-write-for-gfx8.patch"
  patch -Np1 -i "$srcdir/0004-rptr-bounce-buffer-for-no-atomics-platforms.patch"
  patch -Np1 -i "$srcdir/0005-flush-cpu-cache-after-gpu-writes-to-system-memory.patch"

  local _bk=runtime/hsa-runtime/core/runtime/amd_blit_kernel.cpp

  # Phase 7h: L2 scrub after D2H blit to force GPU L2 writeback.
  # The blit kernel writes to the staging buffer (system memory) through
  # GPU L2.  On gfx8 without atomics, the system scope release fence
  # (s_waitcnt) does NOT flush L2.  Dirty L2 lines persist until
  # eviction.  The CPU reads DRAM and may get stale data.
  # Fix: after the blit completes, dispatch a fill kernel on the SAME
  # queue that fills a 512KB VRAM scratch buffer.  This evicts the
  # staging buffer's dirty L2 lines, forcing writeback to DRAM.
  python3 -c "
with open('$_bk') as f: s = f.read()
# Add L2 scrub buffer allocation + flush after the sync copy wait.
# Insert after 'Signal wait returned unexpected value' error check,
# before profiling.
old = '''  if(agent_->profiling_enabled()) {
    LogSignalDuration(HSA_AMD_LOG_FLAG_BLIT_KERNEL_PKTS, completion_signal_,
                      \"BlitKernel::SubmitLinearCopyCommand\");
  }

  return HSA_STATUS_SUCCESS;'''
new = '''  // Phase 7h: L1 stale read fix moved to GLC flag on flat_load instructions.
  // ExecutePM4 ACQUIRE_MEM hangs from within SubmitLinearCopyCommand (lock_).

  if(agent_->profiling_enabled()) {
    LogSignalDuration(HSA_AMD_LOG_FLAG_BLIT_KERNEL_PKTS, completion_signal_,
                      \"BlitKernel::SubmitLinearCopyCommand\");
  }

  return HSA_STATUS_SUCCESS;'''
assert old in s, 'BlitKernel profiling/return pattern not found'
s = s.replace(old, new, 1)
with open('$_bk', 'w') as f: f.write(s)
print('OK: Phase 7h L2 scrub after D2H blit')
"

  # Add PM4 header include to blit kernel
  sed -i '/#include "core\/inc\/amd_blit_kernel.h"/a\#include "core/inc/amd_gpu_pm4.h"' "$_bk"

  # Phase 7h: Add GLC (globally coherent) flag to ALL blit kernel loads.
  # The blit kernel's L1 (per-CU) caches VRAM reads from previous iterations.
  # BUFFER_WBINVL1_VOL (system scope acquire) only invalidates MTYPE SC/GC
  # lines — VRAM lines are MTYPE NC, so L1 stale lines persist.
  # Fix: GLC=1 on flat_load bypasses L1, reads from L2 (shared, correct).
  # Deterministic — no timing dependency, no PM4, no ioctl.
  python3 -c "
import re
with open('$_bk') as f: s = f.read()
# Add ' glc' to every flat_load line that doesn't already have it
s = re.sub(r'(flat_load_\w+\s+v[^,]+,\s*v\[[^\]]+\])(?!\s*glc)', r'\1 glc', s)
with open('$_bk', 'w') as f: f.write(s)
# Count replacements
import subprocess
n = subprocess.run(['grep', '-c', 'flat_load.*glc', '$_bk'], capture_output=True, text=True)
print(f'OK: GLC added to blit kernel flat_load instructions')
"

  # (RELEASE_MEM TC_WB patch moved below, after _aq is defined)

  # Phase 6a: CPU-wait dep_signals in BlitKernel instead of AQL barriers.
  # On no-atomics platforms, the CP goes idle after an unsatisfied barrier
  # dep and cannot be woken (SLOT_BASED_WPTR=0, no DOORBELL_HIT for same
  # WPTR).  CPU-waiting eliminates ALL barrier packets from blit copies.
  local _blit=runtime/hsa-runtime/core/runtime/amd_blit_kernel.cpp
  cat > /tmp/_blit_cpuwait.c << 'INJECT'
  // No-atomics: CPU-wait for dep signals instead of AQL barrier packets.
  // The CP goes idle after unsatisfied barrier deps with SLOT_BASED_WPTR=0.
  if (agent_->device_type() == core::Agent::kAmdGpuDevice &&
      static_cast<const AMD::GpuAgent*>(agent_)->NoPlatformAtomics() &&
      !dep_signals.empty()) {
    for (auto* sig : dep_signals) {
      while (sig->LoadRelaxed() > 0) { os::YieldThread(); }
    }
    dep_signals.clear();
  }
INJECT
  sed -i '/const uint32_t num_barrier_packet/i\
' "$_blit"
  sed -i '/const uint32_t num_barrier_packet/{
    r /tmp/_blit_cpuwait.c
  }' "$_blit"

  # Phase 6c: Re-enable interrupt-based signal wait.
  local _rt=runtime/hsa-runtime/core/runtime/runtime.cpp
  sed -i '/g_use_interrupt_wait = false;/d' "$_rt"
  local _isig=runtime/hsa-runtime/core/runtime/interrupt_signal.cpp
  sed -i '/#include "core\/inc\/interrupt_signal.h"/a\
#include "core/inc/amd_aql_queue.h"' "$_isig"
  sed -i 's|int64_t value = atomic::Load(\&signal_.value, std::memory_order_relaxed);|int64_t value = atomic::Load(\&signal_.value, std::memory_order_relaxed);\
    AMD::AqlQueue::ProcessAllBounceBuffers();\
    value = atomic::Load(\&signal_.value, std::memory_order_relaxed);|' "$_isig"

  # Phase 7b: Uncached shared memory for non-coherent platforms.
  # On platforms without PCIe atomics, GPU writes bypass CPU cache.
  # Map GPU->CPU shared memory as UC so CPU reads go straight to DRAM.

  # 7b-1: UC RPTR bounce buffer.  Replace flags=0 with AllocateUncached.
  local _aq=runtime/hsa-runtime/core/runtime/amd_aql_queue.cpp
  sed -i 's|agent_->system_allocator()(0x1000, 0x1000, 0)|agent_->system_allocator()(0x1000, 0x1000, core::MemoryRegion::AllocateUncached)|' "$_aq"

  # 7b-2: Remove clflush+mfence from UpdateReadDispatchId (UC makes them unnecessary).
  sed -i '/FlushCpuCache(rptr_gpu_buf_/d' "$_aq"
  sed -i '/CLFLUSH is not ordered/d' "$_aq"
  sed -i '/Fence ensures the invalidation/d' "$_aq"
  sed -i '/_mm_mfence();/d' "$_aq"

  # Phase 7h: Add TC_WB to ExecutePM4's RELEASE_MEM on gfx8.
  # The RELEASE_MEM that completes ExecutePM4 has NO cache action flags,
  # so ACQUIRE_MEM L2 flush may still be in-flight when CPU sees completion.
  # Adding cache action flags makes RELEASE_MEM itself flush L2+L1,
  # guaranteeing all GPU cache data is written back before CPU reads.
  # Phase 7h: RELEASE_MEM TC_WB on AQL event REVERTED — made corruption worse.
  # The TC_WB flags on EVENT_INDEX_AQL interfere with RPTR advancement.
  # L2 flush must go through a separate mechanism (GFX ring ioctl).

  # 7b-3: UC signal pool.  Add AllocateUncached to signal block allocations.
  local _sig=runtime/hsa-runtime/core/runtime/signal.cpp
  sed -i 's,core::MemoryRegion::AllocateNonPaged\, 0),core::MemoryRegion::AllocateNonPaged | core::MemoryRegion::AllocateUncached\, 0),g' "$_sig"

  # 7e: UC all CPU->GPU shared memory in the blit data path.
  # On no-atomics platforms, CPU WB-cached writes may not reach DRAM
  # before the GPU reads via PCIe.  Make every region UC.
  local _bk=runtime/hsa-runtime/core/runtime/amd_blit_kernel.cpp
  local _ga=runtime/hsa-runtime/core/runtime/amd_gpu_agent.cpp

  # 7e-1: Blit kernarg pool (src/dst/size args read by blit kernel).
  sed -i 's|16, core::MemoryRegion::AllocateNoFlags)|16, core::MemoryRegion::AllocateUncached)|' "$_bk"

  # 7e-2: AQL ring buffer (packets read by CP).  Target the system_allocator
  #        path only (line after "} else {"), not the coarsegrain path.
  sed -i '/ring_buf_ = agent_->system_allocator/,/AllocateExecutable);/{
    s,AllocateExecutable);,AllocateExecutable | core::MemoryRegion::AllocateUncached);,
  }' "$_aq"

  # 7e-3: Blit kernel code object (instruction fetch by GPU).
  sed -i 's,AllocateExecutableBlitKernelObject),AllocateExecutableBlitKernelObject | core::MemoryRegion::AllocateUncached),' "$_ga"

  # 7e-4: PM4 indirect buffer (icache invalidation commands).
  sed -i 's,pm4_ib_size_b_\, 0x1000\, core::MemoryRegion::AllocateExecutable),pm4_ib_size_b_\, 0x1000\, core::MemoryRegion::AllocateExecutable | core::MemoryRegion::AllocateUncached),' "$_aq"

  # Phase 7h: Full-stack HDP flush with hardware completion.
  #
  # Layer 1: KFD ioctl (kernel) — WREG32(GPU_HDP_FLUSH_REQ) + poll RREG32(DONE)
  # Layer 2: Thunk (libhsakmt) — hsaKmtHdpFlush() wrapper
  # Layer 3: Driver (KfdDriver) — HdpFlush() method
  # Layer 4: GpuAgent — HdpFlushWait() public API
  # Layer 5: AqlQueue/CLR — calls before dispatch

  # --- Layer 2: Thunk wrapper ---
  local _thunk_q=libhsakmt/src/queues.c
  local _thunk_h=libhsakmt/include/hsakmt/hsakmt.h
  local _thunk_lib=libhsakmt/src/libhsakmt.h

  # Add ioctl struct definition to thunk (mirrors kernel kfd_ioctl.h)
  sed -i '/#include "libhsakmt.h"/a\
\
\/\* Phase 7h: HDP flush ioctl struct (mirrors kfd_ioctl.h) *\/\
struct kfd_ioctl_hdp_flush_args {\
\tuint32_t gpu_id;\
\tuint32_t flush_mask;\
\tuint32_t queue_id;\
\tuint32_t timeout_us;\
\tuint32_t actual_us;\
\tuint32_t status;\
};\
\
\/* ioctl number — must match kernel kfd_ioctl.h *\/\
\#define AMDKFD_IOC_HDP_FLUSH _IOWR('"'"'K'"'"', 0x27, struct kfd_ioctl_hdp_flush_args)' "$_thunk_q"

  # Add hsaKmtHdpFlush implementation at end of queues.c
  cat >> "$_thunk_q" << 'THUNK_HDP_FLUSH'

/* Phase 7h: Completion-tracked HDP flush via KFD ioctl */
HSAKMT_STATUS HSAKMTAPI hsaKmtHdpFlush(HSAuint32 NodeId, HSAuint32 QueueId,
                              HSAuint32 FlushMask, HSAuint32 TimeoutUs,
                              HSAuint32 *ActualUs)
{
    struct kfd_ioctl_hdp_flush_args args = {0};
    HsaKFDContext *ctx = &hsakmt_primary_kfd_ctx;
    uint32_t gpu_id;
    HSAKMT_STATUS r;

    /* Convert node_id to KFD gpu_id (same pattern as hsaKmtCreateQueue) */
    r = hsakmt_validate_nodeid(NodeId, &gpu_id);
    if (r != HSAKMT_STATUS_SUCCESS) return r;

    args.gpu_id = gpu_id;
    args.queue_id = QueueId;
    args.flush_mask = FlushMask;
    args.timeout_us = TimeoutUs ? TimeoutUs : 10000;

    long err = hsakmt_ioctl(ctx->fd, AMDKFD_IOC_HDP_FLUSH, &args);
    if (err) return HSAKMT_STATUS_ERROR;
    if (ActualUs) *ActualUs = args.actual_us;
    return args.status ? HSAKMT_STATUS_ERROR : HSAKMT_STATUS_SUCCESS;
}
THUNK_HDP_FLUSH

  # Add declaration to thunk header (insert before the HSAKMT_STATUS line above hsaKmtAllocQueueGWS)
  python3 -c "
with open('$_thunk_h') as f: h = f.read()
h = h.replace(
    'HSAKMT_STATUS\nHSAKMTAPI\nhsaKmtAllocQueueGWS(',
    '''HSAKMT_STATUS
HSAKMTAPI
hsaKmtHdpFlush(
                HSAuint32          NodeId,
                HSAuint32          QueueId,
                HSAuint32          FlushMask,
                HSAuint32          TimeoutUs,
                HSAuint32          *ActualUs);

HSAKMT_STATUS
HSAKMTAPI
hsaKmtAllocQueueGWS(''',
    1)
with open('$_thunk_h', 'w') as f: f.write(h)
print('OK: hsaKmtHdpFlush declaration added to hsakmt.h')
"

  # --- Layer 3: KfdDriver method ---
  local _drv_h=runtime/hsa-runtime/core/inc/amd_kfd_driver.h
  local _drv_cpp=runtime/hsa-runtime/core/driver/kfd/amd_kfd_driver.cpp
  local _base_drv=runtime/hsa-runtime/core/inc/driver.h

  # Add virtual method to base Driver class
  sed -i '/virtual.*DestroyQueue/a\
  virtual hsa_status_t HdpFlush(uint32_t node_id, uint32_t timeout_us) const { return HSA_STATUS_SUCCESS; }' "$_base_drv"

  # Add override to KfdDriver
  sed -i '/DestroyQueue.*override/a\
  hsa_status_t HdpFlush(uint32_t node_id, uint32_t timeout_us) const override;' "$_drv_h"

  # Add implementation to KfdDriver (inside namespace, using python)
  python3 -c "
with open('$_drv_cpp') as f: s = f.read()
# Insert before the last function in the file (inside namespace)
import re
# Find a late function to insert before
for marker in ['hsa_status_t KfdDriver::QueryKernelModeDriver', 'hsa_status_t KfdDriver::GetSystemProperties']:
    if marker in s:
        s = s.replace(marker, '''/* Phase 7h: Completion-tracked HDP flush */
hsa_status_t KfdDriver::HdpFlush(uint32_t node_id, uint32_t timeout_us) const {
    HSAKMT_STATUS status = hsaKmtHdpFlush(node_id, 0, 0, timeout_us, nullptr);
    return (status == HSAKMT_STATUS_SUCCESS) ? HSA_STATUS_SUCCESS : HSA_STATUS_ERROR;
}

''' + marker, 1)
        break
with open('$_drv_cpp', 'w') as f: f.write(s)
print('OK: KfdDriver::HdpFlush injected')
"

  # --- Layer 4: GpuAgent public API ---
  local _agent_h=runtime/hsa-runtime/core/inc/amd_gpu_agent.h
  sed -i '/NoPlatformAtomics/a\
\
  \/\/ Phase 7h: completion-tracked HDP flush via KFD ioctl\
  void HdpFlushWait(uint32_t timeout_us = 10000) const;' "$_agent_h"

  local _agent_cpp=runtime/hsa-runtime/core/runtime/amd_gpu_agent.cpp
  python3 -c "
with open('$_agent_cpp') as f: s = f.read()
old = 'lazy_ptr<core::Blit>& GpuAgent::GetBlitObject'
new = '''/* Phase 7h: Completion-tracked HDP flush */
void GpuAgent::HdpFlushWait(uint32_t timeout_us) const {
  if (!no_platform_atomics_) return;
  driver().HdpFlush(node_id(), timeout_us);
}

lazy_ptr<core::Blit>& GpuAgent::GetBlitObject'''
assert old in s
s = s.replace(old, new, 1)
with open('$_agent_cpp', 'w') as f: f.write(s)
print('OK: GpuAgent::HdpFlushWait added')
"

  # Phase 7f (ACQUIRE_MEM L2 WB hack): REMOVED.
  # Root cause was SNOOPED=0 in GPU PTE, not missing L2 flush.
  # Fixed in kernel patch 0009 (ttm_uncached + SNOOPED=1).

  # --- Phase 7h Layer 1: HSA public API (hsa_amd_hdp_flush_wait) ---
  local _ext_h=runtime/hsa-runtime/inc/hsa_ext_amd.h
  local _ext_cpp=runtime/hsa-runtime/core/runtime/hsa_ext_amd.cpp
  local _trace_h=runtime/hsa-runtime/inc/hsa_api_trace.h
  local _trace_cpp=runtime/hsa-runtime/core/runtime/hsa_api_trace.cpp
  local _impl_h=runtime/hsa-runtime/core/inc/hsa_ext_amd_impl.h
  local _table_cpp=runtime/hsa-runtime/core/common/hsa_table_interface.cpp

  # 7h-1a: Add declaration to hsa_ext_amd.h (before closing extern "C")
  python3 -c "
with open('$_ext_h') as f: s = f.read()
# Insert before the last '#ifdef __cplusplus' / '}' / '#endif' block
decl = '''
/**
 * @brief Flush the GPU HDP (Host Data Path) cache and wait for completion.
 *
 * On platforms without PCIe atomics, CPU writes to system memory may not
 * be visible to the GPU until the HDP write path is flushed. This function
 * triggers a hardware-tracked flush (GPU_HDP_FLUSH_REQ/DONE) via KFD.
 *
 * @param[in] agent GPU agent to flush. Must be a GPU agent.
 *
 * @param[in] timeout_us Timeout in microseconds. 0 uses default (10000).
 *
 * @retval ::HSA_STATUS_SUCCESS The flush completed successfully.
 *
 * @retval ::HSA_STATUS_ERROR_NOT_INITIALIZED The HSA runtime has not been
 * initialized.
 *
 * @retval ::HSA_STATUS_ERROR_INVALID_AGENT The agent is not a valid GPU agent.
 */
hsa_status_t HSA_API hsa_amd_hdp_flush_wait(hsa_agent_t agent,
                                             uint32_t timeout_us);

'''
# Find the last occurrence of '#ifdef __cplusplus' that closes extern \"C\"
import re
# Insert before the final closing block
# Insert before the final extern "C" closing block
marker = '#ifdef __cplusplus\n}  // end extern \"C\" block\n#endif\n\n#endif  // header guard'
assert marker in s, 'Could not find extern C closing block'
s = s.replace(marker, decl + marker, 1)
with open('$_ext_h', 'w') as f: f.write(s)
print('OK: hsa_amd_hdp_flush_wait declaration added to hsa_ext_amd.h')
"

  # 7h-1b: Add implementation to hsa_ext_amd.cpp (inside namespace AMD)
  python3 -c "
with open('$_ext_cpp') as f: s = f.read()
impl = '''
/* Phase 7h: Completion-tracked HDP flush — HSA vendor extension */
hsa_status_t hsa_amd_hdp_flush_wait(hsa_agent_t agent_handle,
                                     uint32_t timeout_us) {
  TRY;
  IS_OPEN();

  const core::Agent* agent = core::Agent::Convert(agent_handle);
  IS_VALID(agent);

  if (agent->device_type() != core::Agent::kAmdGpuDevice) {
    return HSA_STATUS_ERROR_INVALID_AGENT;
  }

  const AMD::GpuAgent* gpu_agent = static_cast<const AMD::GpuAgent*>(agent);
  gpu_agent->HdpFlushWait(timeout_us ? timeout_us : 10000);
  return HSA_STATUS_SUCCESS;
  CATCH;
}

'''
# Insert before closing of namespace amd (inside namespace rocr::AMD)
marker = '}   //  namespace amd'
assert marker in s, 'Could not find namespace amd closing brace'
s = s.replace(marker, impl + marker, 1)
with open('$_ext_cpp', 'w') as f: f.write(s)
print('OK: hsa_amd_hdp_flush_wait impl added (namespace AMD)')
"

  # 7h-1c: Add to impl header (function pointer declaration)
  python3 -c "
with open('$_impl_h') as f: s = f.read()
old = 'hsa_status_t\n    hsa_amd_memory_fill(void* ptr, uint32_t value, size_t count);'
new = '''hsa_status_t
    hsa_amd_hdp_flush_wait(hsa_agent_t agent, uint32_t timeout_us);

hsa_status_t
    hsa_amd_memory_fill(void* ptr, uint32_t value, size_t count);'''
assert old in s, 'Could not find hsa_amd_memory_fill in impl header'
s = s.replace(old, new, 1)
with open('$_impl_h', 'w') as f: f.write(s)
print('OK: hsa_amd_hdp_flush_wait added to impl header')
"

  # 7h-1d: Add function pointer to API trace header
  sed -i '/hsa_amd_memory_fill_fn/i\  decltype(hsa_amd_hdp_flush_wait)* hsa_amd_hdp_flush_wait_fn;' "$_trace_h"

  # 7h-1e: Register in API trace table
  sed -i '/hsa_amd_memory_fill_fn/i\  amd_ext_api.hsa_amd_hdp_flush_wait_fn = AMD::hsa_amd_hdp_flush_wait;' "$_trace_cpp"

  # 7h-1f: Add C wrapper in table interface
  python3 -c "
with open('$_table_cpp') as f: s = f.read()
wrapper = '''
// Phase 7h: HDP flush HSA API wrapper
hsa_status_t HSA_API
    hsa_amd_hdp_flush_wait(hsa_agent_t agent, uint32_t timeout_us) {
  return amdExtTable->hsa_amd_hdp_flush_wait_fn(agent, timeout_us);
}

'''
# Insert before hsa_amd_memory_fill wrapper
marker = '// Mirrors Amd Extension Apis'
if marker not in s:
    marker = 'hsa_status_t HSA_API\n    hsa_amd_memory_fill'
assert marker in s, 'Could not find insertion point in table interface'
s = s.replace(marker, wrapper + marker, 1)
with open('$_table_cpp', 'w') as f: f.write(s)
print('OK: hsa_amd_hdp_flush_wait C wrapper added to table interface')
"

  # 7h-1g: Bump ABI version for new table entry
  local _ver_h=runtime/hsa-runtime/inc/hsa_api_trace_version.h
  sed -i 's/HSA_AMD_EXT_API_TABLE_STEP_VERSION          0x08/HSA_AMD_EXT_API_TABLE_STEP_VERSION          0x09/' "$_ver_h"
  sed -i 's/expected_amd_ext_table_size = 624/expected_amd_ext_table_size = 632/' "$_trace_cpp"
  sed -i 's/HSA_AMD_INTERFACE_VERSION_MINOR 15/HSA_AMD_INTERFACE_VERSION_MINOR 16/' "$_ext_h"

  # 7h-1c: Add symbol to export list (hsacore.so.def)
  local _def=runtime/hsa-runtime/hsacore.so.def
  sed -i '/^local:/i\	hsa_amd_hdp_flush_wait;' "$_def"


  # --- Phase 7h Layer 5: StoreRelaxed HDP flush before doorbell ---
  # On no-atomics platforms, flush HDP before writing the doorbell so
  # the GPU sees fresh kernarg/ring data.  Recursion guard prevents
  # HdpFlushWait → ioctl → signal wait → StoreRelaxed → HdpFlushWait loop.
  python3 -c "
with open('$_aq') as f: s = f.read()

# Find StoreRelaxed and inject HDP flush after ScanNewPackets
old = 'void AqlQueue::StoreRelaxed(hsa_signal_value_t value) {\n  ScanNewPackets();'
new = '''void AqlQueue::StoreRelaxed(hsa_signal_value_t value) {
  ScanNewPackets();

  // Phase 7h: Drain IOH + flush HDP before doorbell on no-atomics platforms.
  //
  // On Westmere (PCIe 2.0), the IOH can deliver the doorbell write (PCIe
  // MMIO) to the GPU before prior DRAM writes (kernarg, AQL packet) have
  // committed.  The GPU starts the dispatch and reads partial data.
  //
  // Fix: readback from the AQL ring slot to force the IOH to commit ALL
  // pending DRAM writes for this address range before the doorbell write.
  // Also flush HDP read cache (separate buffer below L2).
  if (no_atomics_) {
    // Phase 7h-debug: dump all GPU DMA target addresses on first call
    { static int d=0; if(d++<5){
      auto rb = reinterpret_cast<uintptr_t>(amd_queue_.hsa_queue.base_address);
      auto re = rb + amd_queue_.hsa_queue.size * 64;
      auto ra = reinterpret_cast<uintptr_t>(rptr_gpu_buf_);
      auto rp = amd_queue_.read_dispatch_id;
      auto wp = amd_queue_.write_dispatch_id;
      fprintf(stderr, \"[ROCR] ring %lx-%lx %u\\\\n\", rb, re, amd_queue_.hsa_queue.size);
      fprintf(stderr, \"[ROCR] rpt %lx wpoll %lx bounce %lx\\\\n\", rp, wp, ra);
      if(ra>=rb&&ra<re) fprintf(stderr, \"[ROCR] OVERLAP bounce\\\\n\");
      if(rp>=rb&&rp<re) fprintf(stderr, \"[ROCR] OVERLAP rpt\\\\n\");
      if(wp>=rb&&wp<re) fprintf(stderr, \"[ROCR] OVERLAP wpoll\\\\n\");
    } }

    // Readback + HDP flush
    uint64_t slot = value & (amd_queue_.hsa_queue.size - 1);
    volatile uint32_t* pkt = (volatile uint32_t*)(
        (char*)amd_queue_.hsa_queue.base_address + slot * 64);
    (void)pkt[15];

    static thread_local bool in_hdp_flush = false;
    if (!in_hdp_flush) {
      in_hdp_flush = true;
      agent_->HdpFlushWait(10000);
      in_hdp_flush = false;
    }
  }'''

assert old in s, 'Could not find StoreRelaxed with ScanNewPackets'
s = s.replace(old, new, 1)
with open('$_aq', 'w') as f: f.write(s)
print('OK: StoreRelaxed HDP flush added to amd_aql_queue.cpp')
"
}

build() {
  local cmake_args=(
    -Wno-dev
    -S "$_dirname"
    -B build
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/opt/rocm
    -D CMAKE_PREFIX_PATH=/opt/rocm
    -D CMAKE_CXX_FLAGS="$CXXFLAGS -DNDEBUG"
    -DBUILD_SHARED_LIBS=ON)
  cmake "${cmake_args[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$_dirname/LICENSE.txt" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
