# Maintainer: David Connolly <david@connol.ly>
# Based on extra/llama.cpp PKGBUILD
#
# llama.cpp built with Vulkan for AMD GPUs (no ROCm dependency).
# Best performance path for gfx803/Polaris on Westmere (no PCIe atomics).

pkgname=llama-cpp-vulkan-polaris
_upstream_pkgname=llama.cpp
pkgver=b8508
pkgrel=4
pkgdesc='LLM inference in C/C++ with Vulkan GPU support'
arch=('x86_64')
url='https://github.com/ggml-org/llama.cpp'
license=('MIT')
depends=(
  'curl'
  'gcc-libs'
  'glibc'
  'vulkan-icd-loader'
)
makedepends=(
  'cmake'
  'git'
  'vulkan-headers'
  'shaderc'
  'glslang'
)
provides=("llama.cpp=$pkgver")
conflicts=('llama.cpp' 'llama-cpp-rocm-polaris')
source=("$_upstream_pkgname-$pkgver::git+$url.git#tag=$pkgver")
sha256sums=('SKIP')

prepare() {
  cd "$_upstream_pkgname-$pkgver"

  # Phase 15: Fix Vulkan memory type selection on small-BAR GPUs.
  # When DEVICE_LOCAL is requested without HOST_VISIBLE, skip memory
  # types on small heaps (visible VRAM via BAR). Prefer invisible VRAM
  # (Heap 0, 1.75GB, fast local) over visible VRAM (Heap 2, 256MB, slow
  # BAR access). Without this, near the 1792MB boundary RADV spills
  # compute buffers to visible VRAM causing 2x slowdown.
  local _vk=ggml/src/ggml-vulkan/ggml-vulkan.cpp
  python3 -c "
with open('$_vk') as f: s = f.read()
old = '''        if ((mem_req->memoryTypeBits & ((uint64_t)1 << i)) &&
            (flags & memory_type.propertyFlags) == flags &&
            mem_props->memoryHeaps[memory_type.heapIndex].size >= mem_req->size) {
            indices.push_back(i);
        }'''
new = '''        if ((mem_req->memoryTypeBits & ((uint64_t)1 << i)) &&
            (flags & memory_type.propertyFlags) == flags &&
            mem_props->memoryHeaps[memory_type.heapIndex].size >= mem_req->size) {
            // Phase 15: On small-BAR GPUs, skip visible VRAM (small DEVICE_LOCAL +
            // HOST_VISIBLE heap) when only DEVICE_LOCAL was requested. Visible VRAM
            // is accessed via PCIe BAR — much slower than invisible local VRAM.
            if (!(flags & vk::MemoryPropertyFlagBits::eHostVisible) &&
                (memory_type.propertyFlags & vk::MemoryPropertyFlagBits::eHostVisible) &&
                mem_props->memoryHeaps[memory_type.heapIndex].size < (1ULL << 30)) {
                continue;  // skip small visible VRAM heap
            }
            indices.push_back(i);
        }'''
assert old in s, 'find_memory_properties pattern not found'
s = s.replace(old, new, 1)
with open('$_vk', 'w') as f: f.write(s)
print('OK: Phase 15 Vulkan memory type selection fixed')
"

  # Phase 15: Enable SSSE3 quant kernels for pre-AVX CPUs (Westmere).
  # SSE4.2 implies SSSE3, but the compiler doesn't define __SSSE3__
  # unless explicitly told. Add the flag so quant code activates.
  local _cpu_cmake=ggml/src/ggml-cpu/CMakeLists.txt
  sed -i '/list(APPEND ARCH_FLAGS -msse4.2)/a\        list(APPEND ARCH_FLAGS -mssse3)' "$_cpu_cmake"

  # Phase 15: Inject SSSE3 branches into K-format quant dot products.
  # The AVX path uses __m128i internally (SSSE3 ops) with __m256 float
  # accumulators. For SSSE3-only, replace __m256 with paired __m128.
  local _quants=ggml/src/ggml-cpu/arch/x86/quants.c

  # Q4_K: Insert SSSE3 branch between __AVX__ and #else
  python3 -c "
with open('$_quants') as f: s = f.read()

# The Q4_K AVX path ends with:
#     *s = hsum_float_8(acc) + _mm_cvtss_f32(acc_m);
# #else
#     ... generic ...
# Find and inject SSSE3 block

old_q4k = '''    *s = hsum_float_8(acc) + _mm_cvtss_f32(acc_m);

#else'''

new_q4k = '''    *s = hsum_float_8(acc) + _mm_cvtss_f32(acc_m);

#elif defined(__SSSE3__)
    // Phase 15: SSSE3 path — same as AVX but with paired __m128 accumulators.
    const __m128i m4 = _mm_set1_epi8(0xF);
    const __m128i m2 = _mm_set1_epi8(0x2);

    __m128 acc_lo = _mm_setzero_ps();
    __m128 acc_hi = _mm_setzero_ps();
    __m128 acc_m = _mm_setzero_ps();

   for (int i = 0; i < nb; ++i) {

        const float d = y[i].d * GGML_CPU_FP16_TO_FP32(x[i].d);
        const float dmin = -y[i].d * GGML_CPU_FP16_TO_FP32(x[i].dmin);

        const uint8_t * GGML_RESTRICT q4 = x[i].qs;
        const int8_t  * GGML_RESTRICT q8 = y[i].qs;

        memcpy(utmp, x[i].scales, 12);
        utmp[3] = ((utmp[2] >> 4) & kmask2) | (((utmp[1] >> 6) & kmask3) << 4);
        const uint32_t uaux = utmp[1] & kmask1;
        utmp[1] = (utmp[2] & kmask2) | (((utmp[0] >> 6) & kmask3) << 4);
        utmp[2] = uaux;
        utmp[0] &= kmask1;

        const __m128i utmps = _mm_set_epi32(utmp[3], utmp[2], utmp[1], utmp[0]);
        const __m128i scales = _mm_cvtepu8_epi16(utmps);
        const __m128i mins = _mm_cvtepu8_epi16(_mm_unpackhi_epi64(utmps, utmps));

        const __m128i q8sums_0 = _mm_loadu_si128((const __m128i*)&y[i].bsums[0]);
        const __m128i q8sums_1 = _mm_loadu_si128((const __m128i*)&y[i].bsums[8]);
        const __m128i q8s = _mm_hadd_epi16(q8sums_0, q8sums_1);
        const __m128i prod = _mm_madd_epi16(mins, q8s);
        acc_m = _mm_add_ps(_mm_mul_ps(_mm_set1_ps(dmin), _mm_cvtepi32_ps(prod)), acc_m);

        __m128i sumi_0 = _mm_setzero_si128();
        __m128i sumi_1 = _mm_setzero_si128();

        __m128i shuffle = _mm_set1_epi16(0x0100);
        for (int j = 0; j < QK_K/64; ++j) {

            const __m128i scale_l = _mm_shuffle_epi8(scales, shuffle);
            shuffle = _mm_add_epi16(shuffle, m2);
            const __m128i scale_h = _mm_shuffle_epi8(scales, shuffle);
            shuffle = _mm_add_epi16(shuffle, m2);

            __m128i q4bits = _mm_loadu_si128((const __m128i*)q4); q4 += 16;
            const __m128i q4l_0 = _mm_and_si128(q4bits, m4);
            const __m128i q4h_0 = _mm_and_si128(_mm_srli_epi16(q4bits, 4), m4);
            q4bits = _mm_loadu_si128((const __m128i*)q4); q4 += 16;
            const __m128i q4l_1 = _mm_and_si128(q4bits, m4);
            const __m128i q4h_1 = _mm_and_si128(_mm_srli_epi16(q4bits, 4), m4);

            const __m128i q8l_0 = _mm_loadu_si128((const __m128i*)q8); q8 += 16;
            __m128i p16l = _mm_maddubs_epi16(q4l_0, q8l_0);
            p16l = _mm_madd_epi16(scale_l, p16l);
            sumi_0 = _mm_add_epi32(sumi_0, p16l);
            const __m128i q8l_1 = _mm_loadu_si128((const __m128i*)q8); q8 += 16;
            p16l = _mm_maddubs_epi16(q4l_1, q8l_1);
            p16l = _mm_madd_epi16(scale_l, p16l);
            sumi_1 = _mm_add_epi32(sumi_1, p16l);

            const __m128i q8h_0 = _mm_loadu_si128((const __m128i*)q8); q8 += 16;
            __m128i p16h = _mm_maddubs_epi16(q4h_0, q8h_0);
            p16h = _mm_madd_epi16(scale_h, p16h);
            sumi_0 = _mm_add_epi32(sumi_0, p16h);
            const __m128i q8h_1 = _mm_loadu_si128((const __m128i*)q8); q8 += 16;
            p16h = _mm_maddubs_epi16(q4h_1, q8h_1);
            p16h = _mm_madd_epi16(scale_h, p16h);
            sumi_1 = _mm_add_epi32(sumi_1, p16h);
        }

        __m128 vd = _mm_set1_ps(d);
        acc_lo = _mm_add_ps(_mm_mul_ps(vd, _mm_cvtepi32_ps(sumi_0)), acc_lo);
        acc_hi = _mm_add_ps(_mm_mul_ps(vd, _mm_cvtepi32_ps(sumi_1)), acc_hi);
    }

    __m128 acc_sum = _mm_add_ps(acc_lo, acc_hi);
    acc_m = _mm_add_ps(acc_m, _mm_movehl_ps(acc_m, acc_m));
    acc_m = _mm_add_ss(acc_m, _mm_movehdup_ps(acc_m));
    acc_sum = _mm_add_ps(acc_sum, _mm_movehl_ps(acc_sum, acc_sum));
    acc_sum = _mm_add_ss(acc_sum, _mm_movehdup_ps(acc_sum));
    *s = _mm_cvtss_f32(acc_sum) + _mm_cvtss_f32(acc_m);

#else'''

assert old_q4k in s, 'Q4_K AVX/else boundary not found'
s = s.replace(old_q4k, new_q4k, 1)
with open('$_quants', 'w') as f: f.write(s)
print('OK: Phase 15 SSSE3 Q4_K kernel injected')
"
}

build() {
  # Phase 15: Override Arch's -march=x86-64 with native Westmere.
  # Without this, GGML_NATIVE=ON has no effect (makepkg.conf wins).
  # -ffast-math enables auto-vectorization of reduction loops (max, sum)
  # and allows the compiler to use reciprocal approximations.
  # Safe for inference (no IEEE-exact float requirement).
  export CFLAGS="${CFLAGS//-march=x86-64/-march=native} -ffast-math -fno-finite-math-only"
  export CXXFLAGS="${CXXFLAGS//-march=x86-64/-march=native} -ffast-math -fno-finite-math-only"

  local cmake_args=(
    -Wno-dev
    -S "$_upstream_pkgname-$pkgver"
    -B build
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
    -D CMAKE_SKIP_RPATH=ON
    -D GGML_VULKAN=ON
    -D BUILD_SHARED_LIBS=ON
    -D GGML_NATIVE=ON
    -D LLAMA_CURL=ON
  )
  cmake "${cmake_args[@]}"
  cmake --build build -j$(nproc)
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 "$_upstream_pkgname-$pkgver/LICENSE" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
